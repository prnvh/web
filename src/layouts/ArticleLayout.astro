---
import BaseLayout from './BaseLayout.astro';
import SummaryBox from '../components/SummaryBox.astro';
import PaperMetaTable from '../components/PaperMetaTable.astro';
import ShareBar from '../components/ShareBar.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import ReadNextGrid from '../components/ReadNextGrid.astro';
import ArticleRail from '../components/ArticleRail.astro';
import {
  formatArticleType,
  formatDate,
  getReadingTimeLabel,
  slugifyTopic,
  type ArticleListItem,
  type ArticleType,
} from '../utils/articles';
import { topicsBySlug } from '../data/topics';

interface TocHeading {
  slug: string;
  text: string;
  depth: number;
}

interface PullQuote {
  text: string;
  attribution?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  type: ArticleType;
  date: string | Date;
  author?: string;
  readingTime?: string | number;
  topics?: string[];
  summary?: string[];
  toc?: TocHeading[];
  related?: ArticleListItem[];
  canonical?: string;
  heroImage?: string;
  pullQuote?: PullQuote;
  headerMode?: 'masthead' | 'compact';
  railBriefs?: ArticleListItem[];
  railNotes?: ArticleListItem[];
  furtherReading?: { label: string; title: string; href: string }[];
}

const {
  title,
  subtitle,
  description,
  type,
  date,
  author,
  readingTime,
  topics = [],
  summary = [],
  toc = [],
  related = [],
  canonical,
  heroImage,
  pullQuote,
  headerMode = type === 'essay' ? 'compact' : 'masthead',
  railBriefs = [],
  railNotes = [],
  furtherReading = [],
} = Astro.props;

const pageClass = `page-article page-${type.replace(/-/g, '-')}`;
const kicker = formatArticleType(type).toUpperCase();
const dateStr = formatDate(date);
const timeStr = getReadingTimeLabel(readingTime);
const topicLinks = topics.map((slug) => ({
  slug,
  label: topicsBySlug[slug]?.title ?? slug.replace(/-/g, ' '),
}));

const h2Sections = toc.filter((h) => h.depth === 2);
const defaultHero =
  type === 'brief'
    ? '/images/brief-hero.jpg'
    : type === 'essay'
      ? '/images/essay-hero.jpg'
      : type === 'field-map'
        ? '/images/field-map-hero.jpg'
        : undefined;
const heroSrc = type === 'research-note' ? undefined : (heroImage ?? defaultHero);
---

<BaseLayout
  title={title}
  description={description ?? subtitle}
  canonical={canonical}
  bodyClass={pageClass}
  headerMode={headerMode}
>
  <article class="article-shell site-container">
    <header class="article-hero-split">
      <div class="article-hero-text">
        <p class="article-kicker">{kicker}</p>
        <h1 class="article-title">{title}</h1>
        {subtitle && <p class="article-subtitle">{subtitle}</p>}
        <p class="article-meta">
          {dateStr}
          {timeStr && <> · {timeStr}</>}
          {author && <> · {author}</>}
        </p>
        {topicLinks.length > 0 && (
          <p class="article-tags">
            {topicLinks.map((t, i) => (
              <>
                {i > 0 && ', '}
                <a href={`/topics/${t.slug}`}>{t.label}</a>
              </>
            ))}
          </p>
        )}
      </div>
      {heroSrc && (
        <figure class="article-hero-media">
          <img src={heroSrc} alt="" width="400" height="500" loading="eager" decoding="async" />
        </figure>
      )}
    </header>

    {type === 'research-note' && (
      <slot name="paper-meta" />
    )}

    {type === 'field-map' && (
      <slot name="orientation" />
    )}

    {summary.length > 0 && (
      <SummaryBox items={summary} variant={type === 'essay' ? 'icon' : 'list'} />
    )}

    {type === 'field-map' ? (
      <div class="fieldmap-body-grid">
        <div>
          {h2Sections.length > 0 && (
            <ol class="fieldmap-sections">
              {h2Sections.map((section, i) => (
                <li class="fieldmap-section">
                  <span class="fieldmap-section__num">{String(i + 1).padStart(2, '0')}</span>
                  <div>
                    <h2 class="fieldmap-section__title">
                      <a href={`#${section.slug}`}>{section.text}</a>
                    </h2>
                  </div>
                  <span class="fieldmap-section__time">{timeStr || ''}</span>
                </li>
              ))}
            </ol>
          )}
          <div class="article-body">
            <slot />
          </div>
        </div>
        <aside class="article-rail" aria-label="Supplementary">
          {h2Sections.length > 0 && (
            <section class="rail-block">
              <h2 class="rail-block__heading">On this page</h2>
              <ul class="rail-toc">
                {h2Sections.map((h) => (
                  <li>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ul>
            </section>
          )}
          {related.length > 0 && (
            <ArticleRail
              heading="Related reading"
              articles={related}
              moreHref="/essays"
              moreLabel="Browse all essays →"
            />
          )}
        </aside>
      </div>
    ) : type === 'essay' ? (
      <>
        <div class="essay-body-grid">
          <div class="article-body">
            <slot />
          </div>
          {pullQuote && (
            <aside class="essay-pull-quote" aria-label="Pull quote">
              <blockquote class="pull-quote">
                {pullQuote.text}
                {pullQuote.attribution && <cite>{pullQuote.attribution}</cite>}
              </blockquote>
            </aside>
          )}
        </div>
        {related.length > 0 && <ReadNextGrid articles={related} />}
      </>
    ) : (
      <div class="article-columns">
        <div class="article-main">
          <div class="article-body">
            <slot />
          </div>
          {type === 'brief' && <ShareBar />}
        </div>
        <aside class="article-rail" aria-label="Supplementary">
          {type === 'brief' && railBriefs.length > 0 && (
            <ArticleRail
              heading="Latest briefs"
              articles={railBriefs}
              moreHref="/briefs"
              moreLabel="View all briefs →"
            />
          )}
          {type === 'research-note' && (
            <>
              {railNotes.length > 0 && (
                <ArticleRail
                  heading="Related notes"
                  articles={railNotes}
                  moreHref="/research-notes"
                  moreLabel="View all notes →"
                />
              )}
              {furtherReading.length > 0 && (
                <section class="rail-block">
                  <h2 class="rail-block__heading">Further reading</h2>
                  {furtherReading.map((item) => (
                    <article class="rail-item">
                      <a href={item.href}>
                        <p class="rail-item__meta">{item.label}</p>
                        <span class="rail-item__title">{item.title}</span>
                      </a>
                    </article>
                  ))}
                  <a class="rail-more" href="/research-notes">View all notes →</a>
                </section>
              )}
            </>
          )}
        </aside>
      </div>
    )}

    <NewsletterBand />
  </article>
</BaseLayout>
