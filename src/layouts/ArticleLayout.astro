---
import BaseLayout from './BaseLayout.astro';
import SummaryBox from '@/components/SummaryBox.astro';
import NewsletterBand from '@/components/NewsletterBand.astro';
import { render } from 'astro:content';
import {
  formatDate,
  typeLabelUpper,
  type Article,
} from '@/lib/articles';
import '@/styles/article.css';

interface Props {
  article: Article;
  variant: 'brief' | 'research-note' | 'essay' | 'field-map';
  heroImage?: string;
  footerVariant?: 'default' | 'essay' | 'compact';
}

const { article, variant, heroImage, footerVariant = 'default' } = Astro.props;
const { title, subtitle, date, readingTime, topics, summary, author } = article.data;
const { Content } = await render(article);
---

<BaseLayout title={title} description={article.data.description} footerVariant={footerVariant}>
  <article class="article-page">
    <div class="site-container">
      <header class:list={['article-hero', { 'article-hero--no-image': !heroImage }]}>
        <div>
          <p class="meta-label">{typeLabelUpper(article.data.type)}</p>
          <h1 class="article-hero__title">{title}</h1>
          {subtitle && <p class="article-hero__subtitle">{subtitle}</p>}
          <p class="meta-line">
            {formatDate(date)} · {readingTime}
            {variant === 'field-map' && ` · By ${author}`}
          </p>
          {topics.length > 0 && (
            <p class="topic-tags">
              {variant === 'essay' ? <>Topics: </> : null}
              {topics.map((t, i) => (
                <>
                  {i > 0 && (variant === 'essay' ? ' ' : ', ')}
                  <a href={`/topics/${t.toLowerCase().replace(/\s+/g, '-').replace(/&/g, '')}`}>{t}</a>
                </>
              ))}
            </p>
          )}
        </div>
        {heroImage && (
          <img
            class:list={['article-hero__image', { 'article-hero__image--tall': variant === 'essay' }]}
            src={heroImage}
            alt=""
            width={220}
            height={variant === 'essay' ? 280 : 200}
          />
        )}
      </header>

      <div class="article-layout">
        <div class="article-main">
          <slot name="before-body" />
          {summary && variant !== 'field-map' && <SummaryBox summary={summary} />}
          <div class="prose">
            <Content />
          </div>
          <slot name="after-body" />
        </div>
        <aside class="article-rail">
          <slot name="rail" />
        </aside>
      </div>
    </div>
  </article>
  <slot name="after-article" />
  <NewsletterBand />
</BaseLayout>
