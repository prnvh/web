---
import BaseLayout from './BaseLayout.astro';
import ArticleTypeLabel from '../components/ArticleTypeLabel.astro';
import MetadataLine from '../components/MetadataLine.astro';
import SummaryBox from '../components/SummaryBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedReading from '../components/RelatedReading.astro';
import NewsletterBlock from '../components/NewsletterBlock.astro';
import type { TocHeading } from '../components/TableOfContents.astro';
import type { ArticleListItem, ArticleType } from '../utils/articles';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  type: ArticleType;
  date: string | Date;
  updated?: string | Date;
  author?: string;
  readingTime?: string | number;
  topics?: string[];
  summary?: string[];
  toc?: TocHeading[];
  related?: ArticleListItem[];
  canonical?: string;
}

const {
  title,
  subtitle,
  description,
  type,
  date,
  author,
  readingTime,
  topics = [],
  summary = [],
  toc = [],
  related = [],
  canonical,
} = Astro.props;

const metadata = { type, date, readingTime, author, topics };
---

<BaseLayout
  title={title}
  description={description ?? subtitle}
  canonical={canonical}
  ogTitle={title}
  ogDescription={description ?? subtitle}
>
  <article class="article-page site-container">
    <div class="article-grid">
      <aside class="article-rail article-rail--left" aria-label="On this page">
        {toc.length > 0 && <TableOfContents headings={toc} />}
        <slot name="left" />
      </aside>

      <div class="article-main">
        <header class="article-header">
          <ArticleTypeLabel type={type} />
          <h1 class="article-title lead-title">{title}</h1>
          {subtitle && <p class="article-subtitle">{subtitle}</p>}
          <div class="article-header-meta">
            <MetadataLine type={type} date={date} readingTime={readingTime} author={author} />
          </div>
          {topics.length > 0 && (
            <p class="article-topics">{topics.join(' / ')}</p>
          )}
        </header>

        {summary.length > 0 && <SummaryBox items={summary} />}

        <slot name="before-body" />

        <div class="article-body prose">
          <slot />
        </div>

        <slot name="after-body" />

        {related.length > 0 && (
          <div class="article-read-next">
            <RelatedReading articles={related} />
          </div>
        )}
      </div>

      <aside class="article-rail article-rail--right" aria-label="Supplementary">
        <slot name="right" />
      </aside>
    </div>

    <div class="article-footer-cta">
      <NewsletterBlock />
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding: 1.75rem 0 3rem;
  }

  .article-grid {
    display: grid;
    gap: 2rem;
  }

  .article-header {
    margin-bottom: 32px;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 82px);
    line-height: 0.92;
    letter-spacing: -0.05em;
    font-weight: 700;
    margin: 0.5rem 0 0.35rem;
    color: var(--text);
    max-width: 14ch;
  }

  .article-subtitle {
    font-family: var(--font-body);
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--muted);
    margin: 0 0 0.85rem;
    max-width: 44ch;
  }

  .article-topics {
    font-family: var(--font-ui);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0.65rem 0 0;
  }

  .article-main :global(.summary-box) {
    margin: 32px 0;
  }

  .article-read-next {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--rule);
    max-width: 680px;
  }

  .article-rail--left {
    display: none;
  }

  .article-rail--right {
    display: none;
  }

  .article-footer-cta {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    max-width: 28rem;
  }

  @media (min-width: 1100px) {
    .article-grid {
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 3rem;
    }

    .article-rail--left {
      display: block;
      position: sticky;
      top: 1.5rem;
      align-self: start;
    }

    .article-header :global(.type-label),
    .article-header-meta {
      display: block;
    }

    .article-main {
      max-width: 720px;
    }
  }

  @media (min-width: 1400px) {
    .article-grid {
      grid-template-columns: 180px minmax(0, 680px) 220px;
    }

    .article-rail--right {
      display: block;
      position: sticky;
      top: 1.5rem;
      align-self: start;
    }
  }
</style>
