---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getArticles, articlePath, formatDate, typeLabel } from '@/lib/articles';
import '@/styles/listing.css';

const articles = await getArticles();
---

<BaseLayout title="All Articles" description="Archive of every piece on Frontier Manual.">
  <div class="site-container">
    <header class="page-header">
      <h1>All Articles</h1>
      <p>Chronological archive. <a href="/search">Search</a> the publication.</p>
    </header>
    <ul class="archive-list">
      {articles.map((item) => (
        <li class="archive-row">
          <span class="archive-row__date">{formatDate(item.data.date)}</span>
          <div>
            <p class="archive-row__type">{typeLabel(item.data.type)}</p>
            <h2 class="archive-row__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h2>
            <p class="archive-row__dek">{item.data.subtitle ?? item.data.description}</p>
            {item.data.topics.length > 0 && (
              <p class="topic-tags" style="margin-top:0.35rem">{item.data.topics.join(' · ')}</p>
            )}
          </div>
          <span class="archive-row__meta">{item.data.readingTime}</span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
