---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleRow from '../../components/ArticleRow.astro';
import { getArticles, toListItem } from '../../utils/articles';

const articles = (await getArticles()).map(toListItem);
const years = [...new Set(articles.map((a) => a.date.getFullYear()))].sort((a, b) => b - a);
---

<BaseLayout title="All Articles" description="Archive of briefs, research notes, essays, and field maps.">
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">All Articles</h1>
      <p class="page-dek">Chronological archive. Use <a href="/search">search</a> for full-text lookup.</p>
    </header>

    {years.map((year) => {
      const group = articles.filter((a) => a.date.getFullYear() === year);
      return (
        <section class="archive-year">
          <h2 class="label archive-year-label">{year}</h2>
          {group.map((article) => (
            <ArticleRow article={article} showTopics />
          ))}
        </section>
      );
    })}
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.75rem 0 3rem; }
  .archive-year { margin-bottom: 1.5rem; }
  .archive-year-label { margin: 0 0 0.5rem; padding-top: 1.25rem; border-top: 1px solid var(--border); display: block; }
  .archive-year:first-of-type .archive-year-label { border-top: 2px solid var(--rule); padding-top: 0; }
</style>
