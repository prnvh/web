---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import PaperMetaTable from '@/components/PaperMetaTable.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { articlePath, formatShortDate, getByType } from '@/lib/articles';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.type === 'research-note');
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.mdx?$/, '') },
    props: { article },
  }));
}

type Props = { article: CollectionEntry<'articles'> };
const { article } = Astro.props;
const notes = await getByType('research-note');
const relatedNotes = notes.filter((n) => n.id !== article.id).slice(0, 3);
const further = article.data.furtherReading;
---

<ArticleLayout article={article} variant="research-note" footerVariant="compact">
  <Fragment slot="before-body">
    {article.data.paper && <PaperMetaTable paper={article.data.paper} />}
  </Fragment>
  <Fragment slot="rail">
    <div class="article-rail__block">
      <h2 class="article-rail__heading">Related Notes</h2>
      {relatedNotes.map((item) => (
        <article class="rail-item">
          <p class="rail-item__date">{formatShortDate(item.data.date)}</p>
          <h3 class="rail-item__title">
            <a href={articlePath(item)}>{item.data.title}</a>
          </h3>
          <p class="rail-item__sum">{item.data.description}</p>
        </article>
      ))}
      <p style="margin-top:0.75rem">
        <a class="link-arrow" href="/research-notes">View all research notes →</a>
      </p>
    </div>
    {further.length > 0 && (
      <div class="article-rail__block">
        <h2 class="article-rail__heading">Further Reading</h2>
        {further.map((item) => (
          <article class="rail-item">
            <p class="rail-reading__type">{item.type}</p>
            <h3 class="rail-item__title">
              {item.url ? <a href={item.url}>{item.title}</a> : item.title}
            </h3>
            <p class="rail-item__sum">{item.meta}</p>
          </article>
        ))}
        <p style="margin-top:0.75rem">
          <a class="link-arrow" href="/articles">View all reading →</a>
        </p>
      </div>
    )}
  </Fragment>
</ArticleLayout>
