---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeaturedStory from '../../components/FeaturedStory.astro';
import ArticleRow from '../../components/ArticleRow.astro';
import { getByType, toListItem } from '../../utils/articles';

const notes = (await getByType('research-note')).map(toListItem);
const featured = notes[0];
const rest = notes.slice(1);
---

<BaseLayout
  title="Research Notes"
  description="Annotated breakdowns of papers, benchmarks, and technical claims."
>
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Research Notes</h1>
      <p class="page-dek">Paper breakdowns, benchmark notes, and technical observations.</p>
    </header>
    {featured && (
      <div class="listing-featured">
        <FeaturedStory article={featured} label="Featured" size="secondary" />
      </div>
    )}
    <div class="listing-feed">
      {rest.map((article) => (
        <ArticleRow article={article} showTopics />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.75rem 0 3rem; }
  .listing-featured { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .listing-feed :global(.article-row:first-child) { border-top: 2px solid var(--rule); }
</style>
