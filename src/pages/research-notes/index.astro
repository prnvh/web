---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getByType, articlePath, formatDate, typeLabelUpper } from '@/lib/articles';
import '@/styles/listing.css';

const notes = await getByType('research-note');
---

<BaseLayout title="Research Notes" description="Annotated breakdowns of papers, benchmarks, and technical claims.">
  <div class="site-container">
    <header class="page-header">
      <h1>Research Notes</h1>
      <p>Annotated breakdowns of papers, benchmarks, and technical claims.</p>
    </header>
    <ul class="archive-list">
      {notes.map((item) => (
        <li class="archive-row">
          <span class="archive-row__date">{formatDate(item.data.date)}</span>
          <div>
            <p class="archive-row__type">{typeLabelUpper(item.data.type)}</p>
            <h2 class="archive-row__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h2>
            <p class="archive-row__dek">{item.data.subtitle ?? item.data.description}</p>
          </div>
          <span class="archive-row__meta">{item.data.readingTime}</span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
