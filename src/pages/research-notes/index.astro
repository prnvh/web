---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteRow from '../../components/NoteRow.astro';
import { getByType, toListItem } from '../../utils/articles';

const notes = (await getByType('research-note')).map(toListItem);
const [featured, ...rest] = notes;
---

<BaseLayout title="Research Notes" description="Paper breakdowns, benchmark notes, and technical observations.">
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Research Notes</h1>
      <p class="page-dek">Paper breakdowns, benchmark notes, and technical observations.</p>
    </header>
    {featured && (
      <div class="listing-lead">
        <NoteRow article={featured} />
      </div>
    )}
    <div class="notes-grid">
      {rest.map((article) => (
        <NoteRow article={article} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.5rem 0 2.5rem; }
  .listing-lead { margin-bottom: 0.5rem; padding-bottom: 1rem; border-bottom: 2px solid var(--rule); }
  .notes-grid { border-top: 1px solid var(--border); }
  @media (min-width: 768px) {
    .notes-grid { display: grid; grid-template-columns: 1fr 1fr; column-gap: 2.5rem; }
  }
</style>
