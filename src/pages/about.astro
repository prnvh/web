---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';
---

<BaseLayout title="About" description={`About ${site.name}`}>
  <div class="site-container prose" style="padding:2rem 0 3rem">
    <h1 style="font-size:2rem;margin-top:0;border:0;padding:0">About</h1>

    <h2>What this is</h2>
    <p>
      {site.name} is an independent publication on frontier AI, research culture, and the systems
      behind technical progress. We publish briefs, research notes, essays, and field maps—not press
      releases.
    </p>

    <h2>Who it is for</h2>
    <p>
      Engineers, researchers, and technical readers who want depth, sources, and clear writing
      without hype.
    </p>

    <h2>What it covers</h2>
    <p>
      AGI research directions, world models, evaluation, compute, interpretability, safety, and the
      policy and industry context around frontier AI—including India’s role in the ecosystem.
    </p>

    <h2>Editorial principles</h2>
    <ul>
      <li>Clarity over hype.</li>
      <li>Sources over vibes.</li>
      <li>Accessible, not shallow.</li>
      <li>Opinion is labeled as opinion.</li>
      <li>Corrections are welcome.</li>
    </ul>

    <h2>Contact</h2>
    <p>
      <a href="mailto:hello@frontiermanual.com">hello@frontiermanual.com</a>
    </p>
  </div>
</BaseLayout>
