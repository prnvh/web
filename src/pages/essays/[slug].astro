---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import ReadNextGrid from '@/components/ReadNextGrid.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getRelated } from '@/lib/articles';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.type === 'essay');
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.mdx?$/, '') },
    props: { article },
  }));
}

type Props = { article: CollectionEntry<'articles'> };
const { article } = Astro.props;
const related = await getRelated(article.data.related);
const heroImage = article.data.heroImage ?? '/images/essay-hero.jpg';
const { pullQuote, pullQuoteAttribution } = article.data;
---

<ArticleLayout
  article={article}
  variant="essay"
  heroImage={heroImage}
  footerVariant="essay"
>
  <Fragment slot="rail">
    {pullQuote && (
      <figure class="pull-quote">
        <blockquote>{pullQuote}</blockquote>
        <cite>— {pullQuoteAttribution ?? 'Frontier Manual'}</cite>
      </figure>
    )}
  </Fragment>
  <ReadNextGrid slot="after-article" articles={related} />
</ArticleLayout>
