---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeaturedStory from '../../components/FeaturedStory.astro';
import ArticleRow from '../../components/ArticleRow.astro';
import { getByType, toListItem } from '../../utils/articles';

const essays = (await getByType('essay')).map(toListItem);
const featured = essays.find((e) => e.featured) ?? essays[0];
const rest = essays.filter((e) => e.slug !== featured?.slug);
---

<BaseLayout
  title="Essays"
  description="Long-form analysis on frontier AI, research directions, and technical change."
>
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Essays</h1>
      <p class="page-dek">Long-form analysis on frontier AI, research directions, and technical change.</p>
    </header>
    {featured && (
      <div class="listing-featured">
        <FeaturedStory article={featured} label="Featured essay" size="lead" />
      </div>
    )}
    <div class="listing-feed">
      {rest.map((article) => (
        <ArticleRow article={article} showTopics />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.75rem 0 3rem; }
  .listing-featured { margin-bottom: 2rem; }
  .listing-feed :global(.article-row:first-child) { border-top: 2px solid var(--rule); }
</style>
