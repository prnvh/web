---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadStory from '../../components/LeadStory.astro';
import ArticleRow from '../../components/ArticleRow.astro';
import { getByType, toListItem } from '../../utils/articles';

const essays = (await getByType('essay')).map(toListItem);
const featured = essays.find((e) => e.featured) ?? essays[0];
const rest = essays.filter((e) => e.slug !== featured?.slug);
---

<BaseLayout
  title="Essays"
  description="Long-form analysis on frontier AI, research directions, and technical change."
>
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Essays</h1>
      <p class="page-dek">Long-form analysis on frontier AI, research directions, and technical change.</p>
    </header>

    {featured && (
      <div class="listing-featured">
        <LeadStory article={featured} />
      </div>
    )}

    <div class="essay-archive">
      {rest.map((article) => (
        <div class="essay-item">
          <ArticleRow article={article} showTopics />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing {
    padding: 1.75rem 0 3rem;
  }

  .listing-featured {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .essay-item {
    border-bottom: 1px solid var(--border);
  }

  .essay-item:first-child {
    border-top: 2px solid var(--rule);
  }

  .essay-item :global(.article-row) {
    border-bottom: none;
    padding: 1rem 0;
  }

  .essay-item :global(.article-row-title) {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    letter-spacing: -0.03em;
    line-height: 1.12;
  }

  .essay-item :global(.article-row-dek) {
    font-size: 17px;
    font-style: italic;
    color: var(--muted);
  }
</style>
