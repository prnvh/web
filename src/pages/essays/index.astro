---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getByType, articlePath, formatDate } from '@/lib/articles';
import '@/styles/listing.css';

const essays = await getByType('essay');
const featured = essays.find((e) => e.data.featured) ?? essays[0];
const rest = essays.filter((e) => e.id !== featured?.id);
---

<BaseLayout title="Essays" description="Long-form analysis on frontier AI and technology.">
  <div class="site-container">
    <header class="page-header">
      <h1>Essays</h1>
      <p>Long-form analysis on frontier AI and technology.</p>
    </header>
    {featured && (
      <article class="archive-row" style="border-top:1px solid var(--border)">
        <span class="archive-row__date">{formatDate(featured.data.date)}</span>
        <div>
          <p class="archive-row__type">Featured Essay</p>
          <h2 class="archive-row__title">
            <a href={articlePath(featured)}>{featured.data.title}</a>
          </h2>
          <p class="archive-row__dek">{featured.data.subtitle}</p>
        </div>
        <span class="archive-row__meta">{featured.data.readingTime}</span>
      </article>
    )}
    <ul class="archive-list">
      {rest.map((item) => (
        <li class="archive-row">
          <span class="archive-row__date">{formatDate(item.data.date)}</span>
          <div>
            <p class="archive-row__type">Essay</p>
            <h2 class="archive-row__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h2>
            <p class="archive-row__dek">{item.data.subtitle ?? item.data.description}</p>
          </div>
          <span class="archive-row__meta">{item.data.readingTime}</span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
