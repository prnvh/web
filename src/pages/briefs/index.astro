---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleRow from '../../components/ArticleRow.astro';
import { getByType, toListItem } from '../../utils/articles';

const briefs = (await getByType('brief')).map(toListItem);
---

<BaseLayout
  title="Briefs"
  description="Short analysis of recent developments in frontier AI and technology."
>
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Briefs</h1>
      <p class="page-dek">Short analysis of recent papers, benchmarks, model releases, and technical shifts.</p>
    </header>
    <div class="listing-feed">
      {briefs.map((article) => (
        <ArticleRow article={article} showTopics />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.75rem 0 3rem; }
  .listing-feed :global(.article-row:first-child) { border-top: 2px solid var(--rule); }
</style>
