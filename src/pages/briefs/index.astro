---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BriefRow from '../../components/BriefRow.astro';
import { getByType, toListItem } from '../../utils/articles';

const briefs = (await getByType('brief')).map(toListItem);
---

<BaseLayout title="Briefs" description="Short analysis of recent developments in frontier AI and technology.">
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Briefs</h1>
      <p class="page-dek">Short analysis of recent papers, benchmarks, model releases, and technical shifts.</p>
    </header>
    <div class="wire-list">
      {briefs.map((article) => (
        <BriefRow article={article} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.5rem 0 2.5rem; }
  .wire-list { border-top: 2px solid var(--rule); }
</style>
