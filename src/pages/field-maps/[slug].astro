---
import ArticleDetail from '../../components/ArticleDetail.astro';
import { getByType, getArticleSlug } from '../../utils/articles';

export async function getStaticPaths() {
  const entries = await getByType('field-map');
  return entries.map((entry) => ({
    params: { slug: getArticleSlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<ArticleDetail entry={entry} />
