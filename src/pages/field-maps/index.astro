---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getByType, toListItem } from '../../utils/articles';

const maps = (await getByType('field-map')).map(toListItem);
---

<BaseLayout
  title="Field Maps"
  description="Evergreen guides to important research areas."
>
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Field Maps</h1>
      <p class="page-dek">Evergreen guides to important research areas — structured like manual chapters.</p>
    </header>
    <div class="maps-grid">
      {maps.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.75rem 0 3rem; }
  .maps-grid { display: grid; gap: 1rem; }
  @media (min-width: 720px) { .maps-grid { grid-template-columns: 1fr 1fr; } }
</style>
