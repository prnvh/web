---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getByType, toListItem } from '../../utils/articles';

const maps = (await getByType('field-map')).map(toListItem);
---

<BaseLayout
  title="Field Maps"
  description="Evergreen guides to research areas — structured like manual chapters."
>
  <div class="listing site-container">
    <header class="listing-header">
      <h1 class="listing-title">Field Maps</h1>
      <p class="listing-dek">
        Durable guides to complicated fields — major camps, key papers, open questions, and reading paths.
      </p>
    </header>
    <div class="maps-grid">
      {maps.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing {
    padding: 2rem 0 3rem;
  }

  .listing-title {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin: 0;
  }

  .listing-dek {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 52ch;
    margin: 0.75rem 0 1.75rem;
    line-height: 1.5;
  }

  .listing-header {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--rule);
  }

  .maps-grid {
    display: grid;
    gap: 1.75rem;
  }

  @media (min-width: 720px) {
    .maps-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
