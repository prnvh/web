---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getByType, articlePath, formatDate } from '@/lib/articles';
import '@/styles/listing.css';

const maps = await getByType('field-map');
---

<BaseLayout title="Field Maps" description="Evergreen guides to complicated research areas.">
  <div class="site-container">
    <header class="page-header">
      <h1>Field Maps</h1>
      <p>Evergreen guides to complicated research areas.</p>
    </header>
    <ul class="archive-list">
      {maps.map((item) => (
        <li class="archive-row">
          <span class="archive-row__date">
            Updated {formatDate(item.data.updated ?? item.data.date)}
          </span>
          <div>
            <p class="archive-row__type">Field Map</p>
            <h2 class="archive-row__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h2>
            <p class="archive-row__dek">{item.data.subtitle ?? item.data.description}</p>
          </div>
          <span class="archive-row__meta">{item.data.readingTime}</span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
