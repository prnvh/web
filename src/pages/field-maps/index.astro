---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MapRow from '../../components/MapRow.astro';
import { getByType, toListItem } from '../../utils/articles';

const maps = (await getByType('field-map')).map(toListItem);
---

<BaseLayout title="Field Maps" description="Durable maps of research areas.">
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Field Maps</h1>
      <p class="page-dek">Durable maps of research areas — evergreen guides with reading paths and open questions.</p>
    </header>
    <div class="maps-list">
      {maps.map((article, i) => (
        <MapRow article={article} index={i + 1} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.5rem 0 2.5rem; }
  .maps-list { border-top: 2px solid var(--rule); }
</style>
