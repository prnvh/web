---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFeatured, getByType, articlePath, formatDate, formatShortDate } from '@/lib/articles';
import { mockupDates } from '@/config/site';
import '@/styles/home.css';

const featured = await getFeatured();
const notes = await getByType('research-note');
const essays = await getByType('essay');
const maps = await getByType('field-map');
const briefs = await getByType('brief');

const latestBriefs = briefs.filter((b) => b.id !== featured?.id).slice(0, 4);

const heroImage = '/images/home-featured.jpg';
---

<BaseLayout footerVariant="home" pageClass="page-home" displayDate={mockupDates.default}>
  <div class="site-container">
    {featured && (
      <section class="home-lead" aria-label="Featured story">
        <div class="home-lead__main">
          <p class="home-lead__kicker">Brief</p>
          <h2 class="home-lead__headline">
            <a href={articlePath(featured)}>{featured.data.title}</a>
          </h2>
          <p class="home-lead__dek">{featured.data.subtitle}</p>
          <p class="home-lead__meta">
            {formatDate(featured.data.date)} · {featured.data.readingTime}
          </p>
          <p class="home-lead__tags">{featured.data.topics.join(' / ')}</p>
        </div>
        <div class="home-lead__image-wrap">
          <img class="home-lead__image" src={heroImage} alt="" width={340} height={453} />
        </div>
        <aside class="home-lead__rail">
          <h3 class="home-rail__title">Latest Briefs</h3>
          {latestBriefs.map((item) => (
            <article class="home-brief-item">
              <p class="home-brief-item__date">{formatShortDate(item.data.date)}</p>
              <h4 class="home-brief-item__title">
                <a href={articlePath(item)}>{item.data.title}</a>
              </h4>
              <p class="home-brief-item__sum">{item.data.description}</p>
            </article>
          ))}
          <p class="home-rail__more">
            <a class="link-arrow" href="/briefs">View all briefs →</a>
          </p>
        </aside>
      </section>
    )}

    <section class="home-columns" aria-label="Sections">
      <div class="home-column">
        <h3 class="home-column__title">Research Notes</h3>
        {notes.slice(0, 2).map((item) => (
          <article class="home-story">
            <p class="home-story__type">Research Note</p>
            <h4 class="home-story__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h4>
            <p class="home-story__sum">{item.data.description}</p>
            <p class="home-story__meta">
              {formatDate(item.data.date)} · {item.data.readingTime}
            </p>
          </article>
        ))}
        <a class="link-arrow" href="/research-notes">View all notes →</a>
      </div>
      <div class="home-column">
        <h3 class="home-column__title">Essays</h3>
        {essays.slice(0, 2).map((item) => (
          <article class="home-story">
            <p class="home-story__type">Essay</p>
            <h4 class="home-story__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h4>
            <p class="home-story__sum">{item.data.description}</p>
            <p class="home-story__meta">
              {formatDate(item.data.date)} · {item.data.readingTime}
            </p>
          </article>
        ))}
        <a class="link-arrow" href="/essays">View all essays →</a>
      </div>
      <div class="home-column">
        <h3 class="home-column__title">Field Maps</h3>
        {maps.slice(0, 2).map((item, i) => (
          <article class="home-story">
            <p class="home-story__type home-story__type--map">
              Field Map {String(i + 1).padStart(2, '0')}
            </p>
            <h4 class="home-story__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h4>
            <p class="home-story__sum">{item.data.description}</p>
            <p class="home-story__meta">
              Updated {formatDate(item.data.updated ?? item.data.date)}
            </p>
          </article>
        ))}
        <a class="link-arrow" href="/field-maps">View all maps →</a>
      </div>
    </section>

    <section class="home-newsletter" aria-labelledby="home-newsletter">
      <div>
        <h2 id="home-newsletter">Get the weekly note.</h2>
        <p>One clear briefing on frontier AI, research, and technology every week or two.</p>
      </div>
      <form class="newsletter-form" action="/subscribe" method="get">
        <label class="sr-only" for="home-email">Email</label>
        <input id="home-email" type="email" name="email" placeholder="Your email address" required />
        <button type="submit">Subscribe</button>
      </form>
    </section>
  </div>
</BaseLayout>
