---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ShareBar from '../components/ShareBar.astro';
import { site } from '../config/site';
import { normalizeSummary } from '../lib/summary';
import {
  formatDate,
  getArticleHref,
  getByType,
  getReadingTimeLabel,
  toListItem,
} from '../utils/articles';

const briefEntries = await getByType('brief');
const briefs = briefEntries.map(toListItem);
const featuredEntry =
  briefEntries.find((e) => e.data.featured) ?? briefEntries[0];
const featured = featuredEntry ? toListItem(featuredEntry) : null;
const featuredSlug = featured?.slug;
const railBriefs = briefs.filter((b) => b.slug !== featuredSlug).slice(0, 4);

let Content: Awaited<ReturnType<typeof render>>['Content'] | null = null;
let summary: string[] = [];

if (featuredEntry) {
  const rendered = await render(featuredEntry);
  Content = rendered.Content;
  summary = normalizeSummary(featuredEntry.data.summary);
}

const heroImage = site.heroImage;
const topicLine = [
  { label: 'World Models', href: '/topics/world-models' },
  { label: 'Representation Learning', href: '/topics/world-models' },
];
---

<BaseLayout title={site.name} description={site.description} bodyClass="page-home">
  {featured && Content && (
    <div class="site-container">
      <div class="fm-columns">
        <article class="fm-main">
          <header class="fm-article-head">
            <p class="fm-kicker">Brief</p>
            <div class="fm-head-row">
              <div>
                <h1 class="fm-title">
                  <a href={getArticleHref(featured)} style="color:inherit;text-decoration:none">
                    {featured.title}
                  </a>
                </h1>
                {(featured.subtitle ?? featured.description) && (
                  <p class="fm-dek">{featured.subtitle ?? featured.description}</p>
                )}
                <p class="fm-meta">
                  <time datetime={featured.date.toISOString()}>{formatDate(featured.date)}</time>
                  {getReadingTimeLabel(featured.readingTime) && (
                    <> · {getReadingTimeLabel(featured.readingTime)}</>
                  )}
                </p>
                <p class="fm-tags">
                  {topicLine.map((t, i) => (
                    <>
                      {i > 0 && ', '}
                      <a href={t.href}>{t.label}</a>
                    </>
                  ))}
                </p>
              </div>
              <figure class="fm-head-media">
                <img src={heroImage} alt="" width="200" height="200" loading="eager" />
              </figure>
            </div>
          </header>

          {summary.length > 0 && (
            <aside class="fm-in-short" aria-label="In short">
              <p class="fm-in-short-label">In Short</p>
              <ul>
                {summary.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </aside>
          )}

          <div class="fm-body">
            <Content />
          </div>

          <ShareBar />
        </article>

        <aside class="fm-rail" aria-label="Latest briefs">
          <h2 class="fm-rail-title">Latest Briefs</h2>
          {railBriefs.map((article) => {
            const dek = article.subtitle ?? article.description ?? '';
            return (
              <article class="fm-rail-item">
                <a href={getArticleHref(article)}>
                  <p class="fm-rail-item-date">
                    <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
                  </p>
                  <span class="fm-rail-item-title">{article.title}</span>
                  {dek && <span class="fm-rail-item-dek">{dek}</span>}
                </a>
              </article>
            );
          })}
          <a class="fm-rail-more" href="/briefs">View all briefs →</a>
        </aside>
      </div>

      <section class="fm-newsletter" aria-labelledby="home-nl">
        <div class="fm-newsletter-inner">
          <div>
            <h2 id="home-nl">The weekly note.</h2>
            <p>
              One thoughtful email on frontier AI research, culture, and the systems behind technical
              progress.
            </p>
          </div>
          <form class="fm-newsletter-form" action="/subscribe" method="get">
            <input type="email" name="email" required placeholder="Your email address" />
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </section>
    </div>
  )}
</BaseLayout>
