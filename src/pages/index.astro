---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedStory from '../components/FeaturedStory.astro';
import ArticleRow from '../components/ArticleRow.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { site } from '../config/site';
import { topics } from '../data/topics';
import { getByType, toListItem } from '../utils/articles';

const featured = (await getByType('brief')).map(toListItem).find((a) => a.featured)
  ?? (await getByType('essay')).map(toListItem).find((a) => a.featured);
const allBriefs = (await getByType('brief')).map(toListItem);
const secondary = allBriefs.filter((a) => a.slug !== featured?.slug).slice(0, 2);
const latestBriefs = allBriefs.slice(0, 5);
const researchNotes = (await getByType('research-note')).map(toListItem).slice(0, 4);
const fieldMaps = (await getByType('field-map')).map(toListItem).slice(0, 2);
---

<BaseLayout title={site.name} description={site.description}>
  <div class="front-page site-container">
    {featured && (
      <section class="front-lead" aria-label="Front page">
        <div class="front-grid">
          <div class="front-main">
            <FeaturedStory article={featured} size="lead" label="Lead" />
          </div>
          <aside class="front-aside">
            <div class="front-secondary">
              {secondary.map((article) => (
                <FeaturedStory article={article} size="secondary" label="Also" />
              ))}
            </div>
            {latestBriefs.length > 0 && (
              <div class="front-briefs">
                <h2 class="label front-section-title">Latest briefs</h2>
                {latestBriefs.slice(0, 4).map((article) => (
                  <ArticleRow article={article} compact />
                ))}
              </div>
            )}
          </aside>
        </div>
      </section>
    )}

    {researchNotes.length > 0 && (
      <section class="front-section" aria-labelledby="research-heading">
        <h2 class="label front-section-title" id="research-heading">Research notes</h2>
        <div class="notes-columns">
          {researchNotes.map((article) => (
            <ArticleRow article={article} />
          ))}
        </div>
        <p class="front-more"><a href="/research-notes">All research notes</a></p>
      </section>
    )}

    {fieldMaps.length > 0 && (
      <section class="front-section" aria-labelledby="maps-heading">
        <h2 class="label front-section-title" id="maps-heading">Field maps</h2>
        <div class="maps-row">
          {fieldMaps.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
        <p class="front-more"><a href="/field-maps">All field maps</a></p>
      </section>
    )}

    <section class="front-section" aria-labelledby="topics-heading">
      <h2 class="label front-section-title" id="topics-heading">Topics</h2>
      <ul class="topic-index">
        {topics.slice(0, 8).map((topic) => (
          <li>
            <a href={`/topics/${topic.slug}`}>{topic.title}</a>
          </li>
        ))}
      </ul>
      <p class="front-more"><a href="/topics">All topics</a></p>
    </section>

    <section class="front-section front-bottom">
      <div class="bottom-grid">
        <div class="bottom-start">
          <h2 class="label front-section-title">Start here</h2>
          <p class="bottom-copy">
            Reading paths for technical readers — foundations, AGI, evaluation, compute, safety, and India & AI.
          </p>
          <a class="front-more" href="/start-here">Open reading paths</a>
        </div>
        <div class="bottom-newsletter">
          <NewsletterSignup compact />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .front-page {
    padding: 1.25rem 0 2.5rem;
  }

  .front-lead {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .front-grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 960px) {
    .front-grid {
      grid-template-columns: 1.55fr 1fr;
      gap: 2.5rem;
      align-items: start;
    }
  }

  .front-secondary :global(.featured-story) {
    margin-bottom: 1rem;
  }

  .front-briefs {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 2px solid var(--rule);
  }

  .front-section-title {
    margin: 0 0 1rem;
    display: block;
  }

  .front-section {
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }

  .notes-columns {
    display: grid;
    gap: 0;
  }

  @media (min-width: 720px) {
    .notes-columns {
      grid-template-columns: 1fr 1fr;
      column-gap: 2rem;
    }

    .notes-columns :global(.article-row:nth-child(odd)) {
      border-right: none;
    }
  }

  .maps-row {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 720px) {
    .maps-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .topic-index {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: 2rem;
  }

  @media (min-width: 640px) {
    .topic-index {
      columns: 3;
    }
  }

  .topic-index li {
    margin-bottom: 0.45rem;
    break-inside: avoid;
  }

  .topic-index a {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--text);
  }

  .topic-index a:hover {
    color: var(--accent);
  }

  .front-more {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 1rem 0 0;
    display: inline-block;
  }

  .bottom-grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 720px) {
    .bottom-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  .bottom-copy {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 0.75rem;
    max-width: 42ch;
  }
</style>
