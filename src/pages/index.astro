---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadStory from '../components/LeadStory.astro';
import SecondaryStory from '../components/SecondaryStory.astro';
import BriefRow from '../components/BriefRow.astro';
import NoteRow from '../components/NoteRow.astro';
import MapRow from '../components/MapRow.astro';
import SectionHeader from '../components/SectionHeader.astro';
import NewsletterBlock from '../components/NewsletterBlock.astro';
import { site } from '../config/site';
import { getByType, toListItem } from '../utils/articles';

const briefs = (await getByType('brief')).map(toListItem);
const notes = (await getByType('research-note')).map(toListItem);
const maps = (await getByType('field-map')).map(toListItem);

const lead = briefs.find((a) => a.featured) ?? briefs[0];
const leadSlug = lead?.slug;
const secondary = briefs.filter((a) => a.slug !== leadSlug).slice(0, 2);
const excludeSlugs = new Set(
  [leadSlug, ...secondary.map((a) => a.slug)].filter(Boolean) as string[],
);
const otherBriefs = briefs.filter((a) => !excludeSlugs.has(a.slug));
const railBriefs = otherBriefs.slice(0, 4);
const sectionBriefs = otherBriefs.slice(4);
const homeNotes = notes.slice(0, 4);
const homeMaps = maps.slice(0, 2);
---

<BaseLayout title={site.name} description={site.description}>
  <div class="front site-container">
    {lead && (
      <section class="front-hero" aria-label="Front page">
        <div class="front-hero-grid">
          <div class="front-hero-main">
            <LeadStory article={lead} />
          </div>
          <aside class="front-hero-side">
            {secondary.map((article) => (
              <SecondaryStory article={article} />
            ))}
            {railBriefs.length > 0 && (
              <div class="front-rail-briefs">
                <p class="label rail-label">Latest briefs</p>
                {railBriefs.map((article) => (
                  <BriefRow article={article} showDek={false} />
                ))}
              </div>
            )}
          </aside>
        </div>
      </section>
    )}

    {sectionBriefs.length > 0 && (
      <section class="front-block">
        <SectionHeader title="Latest Briefs" href="/briefs" linkLabel="All briefs" />
        {sectionBriefs.map((article) => (
          <BriefRow article={article} />
        ))}
      </section>
    )}

    {homeNotes.length > 0 && (
      <section class="front-block">
        <SectionHeader title="Research Notes" href="/research-notes" linkLabel="All notes" />
        <div class="notes-grid">
          {homeNotes.map((article) => (
            <NoteRow article={article} />
          ))}
        </div>
      </section>
    )}

    {homeMaps.length > 0 && (
      <section class="front-block">
        <SectionHeader title="Field Maps" href="/field-maps" linkLabel="All maps" />
        {homeMaps.map((article, i) => (
          <MapRow article={article} index={i + 1} />
        ))}
      </section>
    )}

    <section class="front-block front-block--newsletter">
      <SectionHeader title="Newsletter" />
      <NewsletterBlock />
      <p class="front-start label">
        New here? <a href="/start-here">Start here</a>
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .front {
    padding: 0.5rem 0 2rem;
  }

  .front-hero {
    padding-bottom: 1.75rem;
    margin-bottom: 0.25rem;
    border-bottom: 2px solid var(--rule);
  }

  .front-hero-grid {
    display: grid;
    gap: 1.75rem;
  }

  @media (min-width: 900px) {
    .front-hero-grid {
      grid-template-columns: 3fr 2fr;
      gap: 2.5rem;
      align-items: start;
    }
  }

  .front-rail-briefs {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 2px solid var(--rule);
  }

  .rail-label {
    margin: 0 0 0.5rem;
  }

  .front-block {
    padding: 1.75rem 0;
    border-top: 1px solid var(--border);
  }

  .notes-grid {
    display: grid;
    gap: 0;
  }

  @media (min-width: 768px) {
    .notes-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 2.5rem;
    }
  }

  .front-block--newsletter {
    padding-bottom: 0;
  }

  .front-start {
    margin: 1.25rem 0 0;
    color: var(--faint);
  }

  .front-start a {
    color: var(--text);
  }
</style>
