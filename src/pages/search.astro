---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search Frontier Manual.">
  <div class="site-container" style="padding:2rem 0 3rem">
    <h1 style="font-family:var(--font-serif);font-size:2rem;font-weight:700;margin:0 0 1rem">Search</h1>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search" data-pagefind-ui></div>
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof PagefindUI !== 'undefined') {
          new PagefindUI({ element: '#search', showSubResults: true });
        }
      });
    </script>
  </div>
</BaseLayout>
