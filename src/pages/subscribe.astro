---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterBlock from '../components/NewsletterBlock.astro';
---

<BaseLayout title="Subscribe" description="Get the weekly note.">
  <div class="subscribe-page site-container">
    <header class="page-header">
      <h1 class="page-title">Subscribe</h1>
      <p class="page-dek">One clear briefing every week or two.</p>
    </header>
    <NewsletterBlock />
  </div>
</BaseLayout>

<style>
  .subscribe-page { padding: 1.5rem 0 2.5rem; max-width: 32rem; }
</style>
