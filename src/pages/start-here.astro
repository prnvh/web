---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { articlePath } from '@/lib/articles';

const paths = [
  {
    title: 'Frontier AI foundations',
    level: 'accessible',
    description: 'Core concepts before diving into specialized camps.',
    slugs: ['beyond-scale-obsession', 'world-models-explained'],
  },
  {
    title: 'AGI and world models',
    level: 'intermediate',
    description: 'Prediction, simulation, and planning in learned systems.',
    slugs: ['agi-research-map', 'jepa-latent-prediction-brief', 'world-models-explained'],
  },
  {
    title: 'Evaluation and benchmarks',
    level: 'technical',
    description: 'What we measure and what we miss.',
    slugs: ['beyond-scale-obsession'],
  },
];

const all = await getCollection('articles');
---

<BaseLayout title="Start Here" description="Reading paths for new readers of Frontier Manual.">
  <div class="site-container" style="padding-bottom:3rem">
    <header class="page-header">
      <h1>Start Here</h1>
      <p>
        This publication explains frontier AI and technology for technical readers who want depth
        without unnecessary fog.
      </p>
    </header>

    {paths.map((path) => (
      <section style="margin-bottom:2.5rem">
        <h2 class="home-story__title" style="font-size:1.35rem">{path.title}</h2>
        <p class="meta-line" style="margin-bottom:0.75rem">
          {path.level}
        </p>
        <p class="home-story__sum">{path.description}</p>
        <ul class="archive-list">
          {path.slugs.map((slug) => {
            const item = all.find((a) => a.id.replace(/\.mdx?$/, '') === slug);
            if (!item) return null;
            return (
              <li class="archive-row">
                <span />
                <div>
                  <h3 class="archive-row__title">
                    <a href={articlePath(item)}>{item.data.title}</a>
                  </h3>
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
