---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleRow from '../../components/ArticleRow.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { topics, getTopicBySlug } from '../../data/topics';
import {
  getArticles,
  getArticleSlug,
  getArticlePath,
  toListItem,
} from '../../utils/articles';

export function getStaticPaths() {
  return topics.map((topic) => ({ params: { slug: topic.slug } }));
}

const { slug } = Astro.params;
const topic = getTopicBySlug(slug!);
if (!topic) return Astro.redirect('/topics');

const all = await getArticles();
const bySlug = new Map(all.map((a) => [getArticleSlug(a), a]));
const startHere = topic.startHere
  .map((s) => bySlug.get(s))
  .filter((e): e is NonNullable<typeof e> => Boolean(e))
  .map(toListItem);
const latest = all
  .filter((e) =>
    e.data.topics.some((t) => {
      const n = t.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      return n === topic.slug || n.includes(topic.slug);
    }),
  )
  .slice(0, 6)
  .map(toListItem);
---

<BaseLayout title={topic.title} description={topic.description}>
  <article class="topic-page site-container">
    <header class="topic-chapter-header">
      <p class="label">Topic</p>
      <h1 class="topic-chapter-title">{topic.title}</h1>
      <p class="topic-chapter-dek">{topic.description}</p>
    </header>

    {startHere.length > 0 && (
      <section class="topic-section">
        <h2 class="label topic-section-title">Start here</h2>
        <ol class="start-list">
          {startHere.map((item) => (
            <li>
              <a href={getArticlePath(bySlug.get(item.slug)!)}>{item.title}</a>
              {(item.subtitle ?? item.description) && (
                <span class="start-desc">{item.subtitle ?? item.description}</span>
              )}
            </li>
          ))}
        </ol>
      </section>
    )}

    {latest.length > 0 && (
      <section class="topic-section">
        <h2 class="label topic-section-title">Latest</h2>
        {latest.map((article) => (
          <ArticleRow article={article} compact />
        ))}
      </section>
    )}

    <section class="topic-section">
      <h2 class="label topic-section-title">Key questions</h2>
      <ul class="topic-prose-list">
        {topic.keyQuestions.map((q) => (
          <li>{q}</li>
        ))}
      </ul>
    </section>

    <section class="topic-section">
      <h2 class="label topic-section-title">Core concepts</h2>
      <dl class="glossary">
        {topic.coreConcepts.map(({ term, definition }) => (
          <>
            <dt>{term}</dt>
            <dd>{definition}</dd>
          </>
        ))}
      </dl>
    </section>

    <section class="topic-section topic-newsletter">
      <NewsletterSignup compact />
    </section>
  </article>
</BaseLayout>

<style>
  .topic-page { padding: 1.75rem 0 3rem; max-width: 720px; }
  .topic-chapter-header { padding-bottom: 1.5rem; margin-bottom: 0.5rem; border-bottom: 2px solid var(--rule); }
  .topic-chapter-title { font-family: var(--font-display); font-size: clamp(2.25rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.05em; line-height: 0.95; margin: 0.35rem 0; }
  .topic-chapter-dek { font-family: var(--font-body); font-size: 1.15rem; line-height: 1.55; color: var(--muted); margin: 0; }
  .topic-section { padding: 28px 0; border-top: 1px solid var(--border); }
  .topic-section-title { margin: 0 0 1rem; display: block; }
  .start-list { margin: 0; padding-left: 1.35rem; font-family: var(--font-body); font-size: 18px; }
  .start-list li { margin-bottom: 0.85rem; }
  .start-list a { font-weight: 700; color: var(--text); }
  .start-desc { display: block; font-size: 16px; color: var(--muted); font-weight: 400; margin-top: 0.2rem; }
  .topic-prose-list { font-family: var(--font-body); font-size: 18px; line-height: 1.6; padding-left: 1.25rem; margin: 0; }
  .glossary dt { font-family: var(--font-display); font-weight: 700; margin-top: 1rem; }
  .glossary dd { font-family: var(--font-body); font-size: 16px; color: var(--muted); margin: 0.25rem 0 0; line-height: 1.55; }
  .topic-newsletter { max-width: 26rem; }
</style>
