---
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsletterBand from '@/components/NewsletterBand.astro';
import { topics } from '@/data/topics';
import { getArticles, articlePath, formatDate } from '@/lib/articles';
import '@/styles/listing.css';

export function getStaticPaths() {
  return topics.map((topic) => ({ params: { slug: topic.slug } }));
}

const { slug } = Astro.params;
const topic = topics.find((t) => t.slug === slug);
if (!topic) return Astro.redirect('/topics');

const all = await getArticles();
const inTopic = all.filter((a) =>
  a.data.topics.some((t) => t.toLowerCase().replace(/\s*&\s*/g, ' ').includes(topic.title.toLowerCase().split(' ')[0])),
);
const startHere = inTopic.slice(0, 4);
---

<BaseLayout title={topic.title} description={topic.description}>
  <div class="site-container">
    <header class="page-header">
      <h1>{topic.title}</h1>
      <p>{topic.description}</p>
    </header>

    <section style="margin-bottom:2.5rem">
      <h2 class="home-column__title" style="border:0;padding:0">Start Here</h2>
      <ul class="archive-list">
        {startHere.map((item, i) => (
          <li class="archive-row">
            <span class="archive-row__date">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="archive-row__title">
                <a href={articlePath(item)}>{item.data.title}</a>
              </h3>
              <p class="archive-row__dek">{item.data.description}</p>
            </div>
            <span class="archive-row__meta">{item.data.readingTime}</span>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2 class="home-column__title" style="border:0;padding:0">Latest</h2>
      <ul class="archive-list">
        {inTopic.map((item) => (
          <li class="archive-row">
            <span class="archive-row__date">{formatDate(item.data.date)}</span>
            <div>
              <h3 class="archive-row__title">
                <a href={articlePath(item)}>{item.data.title}</a>
              </h3>
            </div>
            <span class="archive-row__meta">{item.data.readingTime}</span>
          </li>
        ))}
      </ul>
    </section>
  </div>
  <NewsletterBand />
</BaseLayout>
