---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { topics } from '@/data/topics';
import '@/styles/listing.css';
---

<BaseLayout title="Topics" description="Curated hubs on frontier AI research areas.">
  <div class="site-container">
    <header class="page-header">
      <h1>Topics</h1>
      <p>Curated mini-manuals on the fields this publication covers.</p>
    </header>
    <ul class="archive-list">
      {topics.map((topic) => (
        <li class="archive-row">
          <span class="archive-row__date">Hub</span>
          <div>
            <h2 class="archive-row__title">
              <a href={`/topics/${topic.slug}`}>{topic.title}</a>
            </h2>
            <p class="archive-row__dek">{topic.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
