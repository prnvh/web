---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topics } from '../../data/topics';
---

<BaseLayout
  title="Topics"
  description="Curated hubs on frontier AI research areas."
>
  <div class="listing site-container">
    <header class="page-header">
      <h1 class="page-title">Topics</h1>
      <p class="page-dek">Manual-style hubs — reading paths, key questions, and recent coverage by research area.</p>
    </header>
    <ul class="topic-directory">
      {topics.map((topic) => (
        <li>
          <a href={`/topics/${topic.slug}`}>
            <span class="topic-directory-title">{topic.title}</span>
            <span class="topic-directory-desc">{topic.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .listing { padding: 1.75rem 0 3rem; }
  .topic-directory { list-style: none; margin: 0; padding: 0; }
  .topic-directory li { border-top: 1px solid var(--border); }
  .topic-directory li:first-child { border-top: 2px solid var(--rule); }
  .topic-directory a { display: block; padding: 1rem 0; color: inherit; text-decoration: none; }
  .topic-directory a:hover .topic-directory-title { color: var(--accent); text-decoration: underline; }
  .topic-directory-title { display: block; font-family: var(--font-display); font-size: 1.35rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 0.35rem; }
  .topic-directory-desc { display: block; font-family: var(--font-body); font-size: 16px; color: var(--muted); line-height: 1.5; max-width: 58ch; }
</style>
