---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topics } from '../../data/topics';
---

<BaseLayout
  title="Topics"
  description="Curated hubs on frontier AI research areas — start here lists, key questions, and latest coverage."
>
  <div class="topics-page site-container">
    <header class="listing-header">
      <h1 class="listing-title">Topics</h1>
      <p class="listing-dek">
        Manual-style hubs — not tag dumps. Each topic links a reading path, key questions, and recent work.
      </p>
    </header>
    <ul class="topic-index">
      {topics.map((topic) => (
        <li>
          <a href={`/topics/${topic.slug}`}>
            <span class="topic-index-title">{topic.title}</span>
            <span class="topic-index-desc">{topic.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .topics-page {
    padding: 2rem 0 3rem;
  }

  .listing-title {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .listing-dek {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 52ch;
    margin: 0.75rem 0 1.5rem;
    line-height: 1.5;
  }

  .listing-header {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1rem;
  }

  .topic-index {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .topic-index li {
    border-bottom: 1px solid var(--border);
  }

  .topic-index a {
    display: block;
    padding: 1.1rem 0;
    color: inherit;
    text-decoration: none;
  }

  .topic-index a:hover .topic-index-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .topic-index-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .topic-index-desc {
    display: block;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--muted);
    line-height: 1.5;
    max-width: 58ch;
  }
</style>
