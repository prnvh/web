---
import { formatDate, formatArticleType, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  showDek?: boolean;
}

const { article, showDek = true } = Astro.props;
const href = getArticleHref(article);
const dek = article.subtitle ?? article.description ?? '';
const typeLabel = formatArticleType(article.type);
---

<article class="brief-row">
  <a class="brief-row-link" href={href}>
    <p class="label brief-row-meta">
      <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
      <span aria-hidden="true"> · </span>
      <span>{typeLabel}</span>
    </p>
    <h3 class="brief-row-title">{article.title}</h3>
    {showDek && dek && <p class="brief-row-dek">{dek}</p>}
  </a>
</article>

<style>
  .brief-row {
    border-top: 1px solid var(--border);
    padding: 0.65rem 0;
  }

  .brief-row-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .brief-row-meta {
    margin: 0 0 0.25rem;
    color: var(--faint);
  }

  .brief-row-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0;
    color: var(--text);
  }

  .brief-row-dek {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.45;
    color: var(--muted);
    margin: 0.3rem 0 0;
    max-width: 48ch;
  }

  .brief-row-link:hover .brief-row-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
