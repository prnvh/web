---
import { summaryList } from '@/lib/articles';

interface Props {
  summary: string | string[];
  label?: string;
}

const { summary, label = 'In Short' } = Astro.props;
const items = summaryList(summary);
---

<aside class="summary-box" aria-label="Summary">
  <p class="summary-box__label">{label}</p>
  {items.length === 1 ? <p>{items[0]}</p> : (
    <ul>
      {items.map((item) => <li>{item}</li>)}
    </ul>
  )}
</aside>
