---
import { formatDate, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
}

const { article } = Astro.props;
const href = getArticleHref(article);
const dek = article.subtitle ?? article.description ?? '';
---

<article class="note-row">
  <a class="note-row-link" href={href}>
    <p class="label note-row-type">Research Note</p>
    <h3 class="note-row-title">{article.title}</h3>
    {dek && <p class="note-row-dek">{dek}</p>}
    <p class="label note-row-date">{formatDate(article.date)}</p>
  </a>
</article>

<style>
  .note-row {
    border-top: 1px solid var(--border);
    padding: 0.85rem 0;
  }

  .note-row-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .note-row-type {
    margin: 0 0 0.35rem;
    color: var(--faint);
  }

  .note-row-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
    max-width: 34ch;
  }

  .note-row-dek {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0.35rem 0 0.4rem;
    max-width: 46ch;
  }

  .note-row-date {
    margin: 0;
    color: var(--faint);
  }

  .note-row-link:hover .note-row-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
