---
import { site, footerColumns } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-container footer-layout">
    <div class="footer-brand">
      <p class="footer-name">{site.name}</p>
      <p class="footer-desc">{site.tagline}</p>
    </div>

    <div class="footer-cols">
      {footerColumns.map((col) => (
        <nav aria-label="Footer links">
          <ul>
            {col.links.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <p class="footer-copy">
      &copy; {year} {site.name}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 1.5rem;
    padding: 1.5rem 0 2rem;
    border-top: 1px solid var(--border);
  }

  .footer-layout {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 900px) {
    .footer-layout {
      grid-template-columns: minmax(200px, 1.2fr) 1fr 1fr minmax(180px, auto);
      align-items: start;
      gap: 2rem 2.5rem;
    }

    .footer-cols {
      grid-column: 2 / 4;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-copy {
      grid-column: 4;
      justify-self: end;
      align-self: end;
      text-align: right;
    }
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.35rem;
  }

  .footer-desc {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.45;
    color: var(--muted);
    margin: 0;
    max-width: 36ch;
  }

  .footer-cols ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-cols li {
    margin-bottom: 0.35rem;
  }

  .footer-cols a {
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
  }

  .footer-cols a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-copy {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--faint);
    white-space: nowrap;
  }
</style>
