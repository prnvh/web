---
import { site, footerColumns } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-container footer-layout">
    <div class="footer-brand">
      <p class="footer-name">{site.name}</p>
      <p class="footer-desc">{site.tagline}</p>
    </div>

    <div class="footer-cols">
      {footerColumns.map((col) => (
        <nav aria-label="Footer links">
          <ul>
            {col.links.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <p class="footer-copy">
      &copy; {year} {site.name}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 1.5rem;
    padding: 1.75rem 0 2.25rem;
    border-top: 1px solid var(--border);
  }

  .footer-layout {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .footer-layout {
      grid-template-columns: minmax(200px, 1.15fr) 2.2fr minmax(200px, auto);
      gap: 2.5rem 3rem;
      align-items: start;
    }

    .footer-cols {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .footer-copy {
      justify-self: end;
      align-self: end;
      text-align: right;
    }
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.4rem;
  }

  .footer-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.45;
    color: var(--muted);
    margin: 0;
    max-width: 34ch;
  }

  .footer-cols ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-cols li {
    margin-bottom: 0.4rem;
  }

  .footer-cols a {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text);
    text-decoration: none;
  }

  .footer-cols a:hover {
    color: var(--accent);
  }

  .footer-copy {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--faint);
  }

</style>
