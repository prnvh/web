---
import { site, footerLinks } from '../config/site';
import NewsletterSignup from './NewsletterSignup.astro';
---

<footer class="site-footer">
  <div class="site-container">
    <div class="footer-top">
      <p class="footer-name">{site.name}</p>
      <p class="footer-desc">{site.description}</p>
    </div>

    <NewsletterSignup compact />

    <nav class="footer-links" aria-label="Footer">
      <ul>
        {footerLinks.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="footer-copy">
      &copy; {new Date().getFullYear()} {site.name}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 3rem;
    padding: 2rem 0 2.25rem;
    border-top: 2px solid var(--rule);
    background: var(--bg);
  }

  .footer-top {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.4rem;
    color: var(--text);
  }

  .footer-desc {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
    max-width: 48ch;
  }

  .site-footer :global(.newsletter) {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .footer-links ul {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.25rem;
  }

  .footer-links a {
    font-family: var(--font-ui);
    font-size: var(--text-label-size);
    letter-spacing: var(--text-label-tracking);
    text-transform: uppercase;
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-copy {
    font-family: var(--font-ui);
    font-size: var(--text-label-size);
    letter-spacing: var(--text-meta-tracking);
    text-transform: uppercase;
    color: var(--faint);
    margin: 0;
  }
</style>
