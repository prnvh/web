---
import { site, footerLinks } from '../config/site';
import NewsletterSignup from './NewsletterSignup.astro';
---

<footer class="site-footer">
  <div class="site-container">
    <p class="footer-name">{site.name}</p>
    <p class="footer-desc">{site.description}</p>

    <div class="footer-form">
      <NewsletterSignup compact />
    </div>

    <nav class="footer-links" aria-label="Footer">
      <ul>
        {footerLinks.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="footer-copy label">&copy; {new Date().getFullYear()} {site.name}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 2.5rem;
    padding: 1.5rem 0 2rem;
    border-top: 2px solid var(--rule);
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.35rem;
  }

  .footer-desc {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 1.25rem;
    max-width: 40ch;
  }

  .footer-form {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
    max-width: 28rem;
  }

  .footer-links ul {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1rem;
  }

  .footer-links a {
    font-family: var(--font-ui);
    font-size: 10.5px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-copy {
    margin: 0;
    color: var(--faint);
  }
</style>
