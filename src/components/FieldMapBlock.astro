---
import { formatDate, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  index?: number;
}

const { article, index } = Astro.props;
const href = getArticleHref(article);
const dek = article.subtitle ?? article.description ?? '';
---

<article class="field-map-block">
  <a class="field-map-link" href={href}>
    {index !== undefined && <span class="field-map-num">{String(index).padStart(2, '0')}</span>}
    <div class="field-map-body">
      <p class="label field-map-label">Field Map</p>
      <h3 class="field-map-title">{article.title}</h3>
      {dek && <p class="field-map-dek">{dek}</p>}
      <p class="label field-map-meta">
        Updated {formatDate(article.date)}
        {article.topics?.length ? ` · ${article.topics.join(' · ')}` : ''}
      </p>
    </div>
  </a>
</article>

<style>
  .field-map-block {
    border-top: 2px solid var(--rule);
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
  }

  .field-map-link {
    display: flex;
    gap: 1.25rem;
    color: inherit;
    text-decoration: none;
  }

  .field-map-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--faint);
    flex-shrink: 0;
    width: 2.5rem;
  }

  .field-map-label {
    margin: 0 0 0.4rem;
    color: var(--accent);
  }

  .field-map-title {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin: 0;
    max-width: 28ch;
  }

  .field-map-dek {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0.45rem 0 0.55rem;
    max-width: 44ch;
  }

  .field-map-meta {
    margin: 0;
    color: var(--faint);
  }

  .field-map-link:hover .field-map-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
