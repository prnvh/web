---
import { site } from '../config/site';
---

<section class="newsletter-band" aria-labelledby="newsletter-band-heading">
  <div class="site-container newsletter-band__inner">
    <div>
      <h2 class="newsletter-band__title" id="newsletter-band-heading">The weekly note.</h2>
      <p class="newsletter-band__dek">
        One thoughtful email on frontier AI research, culture, and the systems behind technical progress.
      </p>
    </div>
    <form class="newsletter-band__form" action={site.subscribePath} method="get">
      <label class="visually-hidden" for="band-email">Email</label>
      <input id="band-email" name="email" type="email" required placeholder="Your email address" />
      <button type="submit" class="button">Subscribe</button>
    </form>
  </div>
</section>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }
</style>
