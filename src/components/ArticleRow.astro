---
import ArticleTypeLabel from './ArticleTypeLabel.astro';
import { formatDate, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  dek?: string;
  showTopics?: boolean;
}

const { article, dek, showTopics = false } = Astro.props;
const href = getArticleHref(article);
const description = dek ?? article.subtitle ?? article.description ?? '';
const dateLabel = formatDate(article.date);
const readingLabel =
  article.readingTime !== undefined
    ? typeof article.readingTime === 'number'
      ? `${article.readingTime} min`
      : article.readingTime
    : null;
---

<article class="article-row">
  <a class="article-row-link" href={href}>
    <div class="article-row-meta label">
      <time datetime={typeof article.date === 'string' ? article.date : article.date.toISOString()}>
        {dateLabel}
      </time>
      <span class="sep" aria-hidden="true">·</span>
      <ArticleTypeLabel type={article.type} />
      {readingLabel && (
        <>
          <span class="sep" aria-hidden="true">·</span>
          <span class="reading">{readingLabel}</span>
        </>
      )}
    </div>
    <h3 class="article-row-title">{article.title}</h3>
    {description && <p class="article-row-dek">{description}</p>}
  </a>
  {showTopics && article.topics && article.topics.length > 0 && (
    <p class="article-row-topics label">{article.topics.join(' · ')}</p>
  )}
</article>

<style>
  .article-row {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }

  .article-row-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .article-row-link:hover .article-row-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-row-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.25rem;
  }

  .article-row-meta :global(.type-label) {
    color: var(--muted);
  }

  .sep {
    color: var(--faint);
  }

  .reading {
    color: var(--faint);
  }

  .article-row-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0;
    color: var(--text);
  }

  .article-row-dek {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.45;
    color: var(--muted);
    margin: 0.35rem 0 0;
    max-width: 52ch;
  }

  .article-row-topics {
    margin: 0.35rem 0 0;
    color: var(--faint);
  }
</style>
