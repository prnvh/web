---
import { site } from '../config/site';

interface Props {
  homeHref?: string;
}

const { homeHref = '/' } = Astro.props;
---

<div class="masthead">
  <a class="masthead-link" href={homeHref}>
    <span class="masthead-name">{site.name}</span>
    {site.tagline && <span class="masthead-tagline">{site.tagline}</span>}
  </a>
</div>

<style>
  .masthead {
    text-align: center;
    padding: 1.25rem 0 0.85rem;
    border-bottom: 1px solid var(--rule);
  }

  .masthead-link {
    color: inherit;
    text-decoration: none;
    display: inline-block;
  }

  .masthead-link:hover .masthead-name {
    color: var(--accent);
  }

  .masthead-name {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--text);
  }

  .masthead-tagline {
    display: block;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--faint);
    margin-top: 0.45rem;
  }
</style>
