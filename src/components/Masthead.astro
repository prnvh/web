---
import { site } from '../config/site';

interface Props {
  homeHref?: string;
}

const { homeHref = '/' } = Astro.props;
---

<div class="masthead">
  <a class="masthead-link" href={homeHref}>
    <span class="masthead-title">{site.name}</span>
  </a>
</div>

<style>
  .masthead {
    text-align: center;
    padding: 1rem 0 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .masthead-link {
    color: inherit;
    text-decoration: none;
    display: inline-block;
  }

  .masthead-link:hover .masthead-title {
    color: var(--accent);
  }

  .masthead-title {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(48px, 9vw, 112px);
    line-height: 0.85;
    letter-spacing: -0.06em;
    font-weight: 700;
    color: var(--text);
  }
</style>
