---
import { formatDate, formatArticleType, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  articles: ArticleListItem[];
}

const { articles } = Astro.props;
---

<div class="brief-rail">
  <h2 class="label brief-rail-heading">Latest briefs</h2>
  <ul class="brief-rail-list">
    {articles.map((article) => {
      const dek = article.subtitle ?? article.description ?? '';
      return (
        <li class="brief-rail-item">
          <a href={getArticleHref(article)}>
            <p class="label brief-rail-meta">
              <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
              <span aria-hidden="true"> · </span>
              {formatArticleType(article.type)}
            </p>
            <span class="brief-rail-title">{article.title}</span>
            {dek && <span class="brief-rail-dek">{dek}</span>}
          </a>
        </li>
      );
    })}
  </ul>
  <a class="col-more" href="/briefs">View all briefs →</a>
</div>

<style>
  .brief-rail-heading {
    margin: 0 0 0.75rem;
    display: block;
  }

  .brief-rail-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .brief-rail-item {
    border-top: 1px solid var(--border);
    padding: 0.65rem 0;
  }

  .brief-rail-item a {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .brief-rail-meta {
    margin: 0 0 0.25rem;
    color: var(--faint);
  }

  .brief-rail-title {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text);
  }

  .brief-rail-dek {
    display: block;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.4;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .brief-rail-item a:hover .brief-rail-title {
    color: var(--accent);
    text-decoration: underline;
  }

  .col-more {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--font-ui);
    font-size: 10.5px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
