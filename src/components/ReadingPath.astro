---
export interface PathArticle {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  articles: PathArticle[];
  difficulty?: 'accessible' | 'intermediate' | 'technical' | string;
}

const { title, description, articles, difficulty } = Astro.props;
---

<article class="reading-path">
  <header class="reading-path-header">
    <h3 class="reading-path-title">{title}</h3>
    {difficulty && <span class="reading-path-level">{difficulty}</span>}
  </header>
  <p class="reading-path-desc">{description}</p>
  {articles.length > 0 && (
    <ol class="reading-path-list">
      {articles.map((item) => (
        <li>
          <a href={item.href}>{item.title}</a>
        </li>
      ))}
    </ol>
  )}
</article>

<style>
  .reading-path {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .reading-path-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .reading-path-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--text);
  }

  .reading-path-level {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .reading-path-desc {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0 0 0.65rem;
    max-width: 55ch;
  }

  .reading-path-list {
    margin: 0;
    padding-left: 1.25rem;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.5;
  }

  .reading-path-list a {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .reading-path-list a:hover {
    color: var(--accent);
  }

  .reading-path-list li + li {
    margin-top: 0.3rem;
  }
</style>
