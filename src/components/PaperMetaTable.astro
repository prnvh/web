---
interface Props {
  paper: string;
  year?: string | number;
  authors?: string;
  source?: string;
  sourceUrl?: string;
}

const { paper, year, authors, source, sourceUrl } = Astro.props;
---

<aside class="fm-paper-table" slot="paper-meta" aria-label="Paper metadata">
  <div class="fm-paper-cell">
    <p class="fm-paper-label">Paper</p>
    <p class="fm-paper-value">{paper}</p>
  </div>
  {year !== undefined && (
    <div class="fm-paper-cell">
      <p class="fm-paper-label">Year</p>
      <p class="fm-paper-value">{year}</p>
    </div>
  )}
  {authors && (
    <div class="fm-paper-cell">
      <p class="fm-paper-label">Authors</p>
      <p class="fm-paper-value">{authors}</p>
    </div>
  )}
  <div class="fm-paper-cell">
    <p class="fm-paper-label">Source</p>
    <p class="fm-paper-value">
      {sourceUrl ? (
        <a href={sourceUrl} rel="noopener noreferrer">{source ?? 'Link'} ↗</a>
      ) : (
        (source ?? '—')
      )}
    </p>
  </div>
</aside>
