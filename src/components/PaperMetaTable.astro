---
interface Paper {
  title: string;
  authors: string;
  year: string;
  source: string;
  url?: string;
}

const { paper } = Astro.props as { paper: Paper };
---

<div class="paper-meta">
  <div>
    <p class="paper-meta__label">Paper</p>
    <p class="paper-meta__value">{paper.title}</p>
  </div>
  <div>
    <p class="paper-meta__label">Year</p>
    <p class="paper-meta__value">{paper.year}</p>
  </div>
  <div>
    <p class="paper-meta__label">Authors</p>
    <p class="paper-meta__value">{paper.authors}</p>
  </div>
  <div>
    <p class="paper-meta__label">Source</p>
    <p class="paper-meta__value">
      {paper.url ? (
        <a href={paper.url} target="_blank" rel="noopener noreferrer">
          {paper.source} ↗
        </a>
      ) : (
        paper.source
      )}
    </p>
  </div>
</div>
