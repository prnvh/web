---
interface Props {
  paper: string;
  year?: string | number;
  authors?: string;
  source?: string;
  sourceUrl?: string;
}

const { paper, year, authors, source, sourceUrl } = Astro.props;
const sourceLabel = source ?? 'Paper';
---

<aside class="paper-meta-table" aria-label="Paper metadata">
  <div class="paper-meta-table__cell">
    <p class="paper-meta-table__label">Paper</p>
    <p class="paper-meta-table__value">{paper}</p>
  </div>
  {year !== undefined && (
    <div class="paper-meta-table__cell">
      <p class="paper-meta-table__label">Year</p>
      <p class="paper-meta-table__value">{year}</p>
    </div>
  )}
  {authors && (
    <div class="paper-meta-table__cell">
      <p class="paper-meta-table__label">Authors</p>
      <p class="paper-meta-table__value">{authors}</p>
    </div>
  )}
  {(sourceUrl || source) && (
    <div class="paper-meta-table__cell">
      <p class="paper-meta-table__label">Source</p>
      <p class="paper-meta-table__value">
        {sourceUrl ? (
          <a href={sourceUrl} rel="noopener noreferrer">
            {sourceLabel} ↗
          </a>
        ) : (
          sourceLabel
        )}
      </p>
    </div>
  )}
</aside>
