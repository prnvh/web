---
import { formatDate, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
}

const { article } = Astro.props;
const href = getArticleHref(article);
---

<article class="brief-wire">
  <a class="brief-wire-link" href={href}>
    <span class="label brief-wire-line">
      <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
      <span aria-hidden="true"> · </span>
      <span>Brief</span>
      <span aria-hidden="true"> · </span>
      <span class="brief-wire-headline">{article.title}</span>
    </span>
  </a>
</article>

<style>
  .brief-wire {
    padding: 0.45rem 0;
    border-top: 1px solid var(--border);
  }

  .brief-wire:first-child {
    border-top: none;
  }

  .brief-wire-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .brief-wire-line {
    display: block;
    color: var(--faint);
    font-weight: 500;
  }

  .brief-wire-headline {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.25;
    text-transform: none;
    color: var(--text);
  }

  .brief-wire-link:hover .brief-wire-headline {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
