---
import ArticleRow from './ArticleRow.astro';
import type { ArticleListItem } from '../utils/articles';

interface Props {
  articles: ArticleListItem[];
  heading?: string;
  max?: number;
}

const { articles, heading = 'Read Next', max = 3 } = Astro.props;
const items = articles.slice(0, max);
---

{items.length > 0 && (
  <section class="related-reading" aria-labelledby="related-reading-heading">
    <h2 class="label related-heading" id="related-reading-heading">{heading}</h2>
    <div class="related-list">
      {items.map((article) => (
        <ArticleRow article={article} compact />
      ))}
    </div>
  </section>
)}

<style>
  .related-heading {
    margin: 0 0 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    display: block;
  }

  .related-list :global(.article-row:first-child) {
    border-top: none;
  }
</style>
