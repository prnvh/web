---
import MetadataLine from './MetadataLine.astro';
import { getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  dek?: string;
  label?: string;
}

const { article, dek, label = 'Featured' } = Astro.props;
const href = getArticleHref(article);
const description = dek ?? article.subtitle ?? article.description ?? '';
---

<article class="featured-story">
  <p class="featured-label">{label}</p>
  <a class="featured-link" href={href}>
    <h2 class="featured-title">{article.title}</h2>
    {description && <p class="featured-dek">{description}</p>}
  </a>
  <MetadataLine
    type={article.type}
    date={article.date}
    readingTime={article.readingTime}
    topics={article.topics}
  />
</article>

<style>
  .featured-story {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--rule);
  }

  .featured-label {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.65rem;
  }

  .featured-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .featured-link:hover .featured-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin: 0;
    color: var(--text);
    max-width: 18ch;
  }

  .featured-dek {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0.85rem 0 0.75rem;
    max-width: 42ch;
  }

  .featured-story :global(.metadata-line) {
    margin-top: 0.75rem;
  }
</style>
