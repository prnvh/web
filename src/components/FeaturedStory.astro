---
import LeadStory from './LeadStory.astro';
import SecondaryStory from './SecondaryStory.astro';
import type { ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  dek?: string;
  label?: string;
  size?: 'lead' | 'secondary';
}

const { article, dek, label, size = 'lead' } = Astro.props;
---

{size === 'lead' ? (
  <LeadStory article={article} dek={dek} label={label ?? 'Lead'} />
) : (
  <SecondaryStory article={article} dek={dek} label={label ?? 'Also'} />
)}
