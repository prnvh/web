---
import { formatDate, formatArticleType, getArticleHref, getReadingTimeLabel, type ArticleListItem } from '../utils/articles';
import { topicsBySlug } from '../data/topics';

function topicLabel(slug: string): string {
  const meta = topicsBySlug[slug.toLowerCase()];
  if (meta) return meta.title;
  return slug
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

interface TopicLink {
  label: string;
  href: string;
}

interface Props {
  article: ArticleListItem;
  dek?: string;
  topicLinks?: TopicLink[];
}

const { article, dek, topicLinks } = Astro.props;
const href = getArticleHref(article);
const description = dek ?? article.subtitle ?? article.description ?? '';
const typeLabel = formatArticleType(article.type).toUpperCase();
const topics = article.topics?.slice(0, 3) ?? [];
const links =
  topicLinks ??
  topics.map((topic) => ({
    label: topicLabel(topic),
    href: `/topics/${topic}`,
  }));
const timeLabel = getReadingTimeLabel(article.readingTime);
---

<article class="lead-story">
  <p class="label lead-type">{typeLabel}</p>
  <a class="lead-link" href={href}>
    <h2 class="lead-title">{article.title}</h2>
    {description && <p class="lead-dek">{description}</p>}
  </a>
  <p class="lead-meta">
    <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
    {timeLabel && <span> · {timeLabel}</span>}
  </p>
  {links.length > 0 && (
    <p class="lead-topics">
      {links.map((link, i) => (
        <>
          {i > 0 && <span aria-hidden="true">, </span>}
          <a href={link.href}>{link.label}</a>
        </>
      ))}
    </p>
  )}
</article>

<style>
  .lead-type {
    margin: 0 0 0.5rem;
    color: var(--accent);
  }

  .lead-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .lead-link:hover .lead-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .lead-dek {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0.7rem 0 0;
    max-width: 36ch;
  }

  .lead-meta {
    font-family: var(--font-ui);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--faint);
    margin: 0.85rem 0 0;
  }

  .lead-topics {
    font-family: var(--font-ui);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0.5rem 0 0;
  }

  .lead-topics a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
