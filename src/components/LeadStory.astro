---
import MetadataLine from './MetadataLine.astro';
import TopicPill from './TopicPill.astro';
import { getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  dek?: string;
  label?: string;
}

const { article, dek, label = 'Lead' } = Astro.props;
const href = getArticleHref(article);
const description = dek ?? article.subtitle ?? article.description ?? '';
const topics = article.topics?.slice(0, 3) ?? [];
---

<article class="lead-story">
  <p class="label lead-label">{label}</p>
  <a class="lead-link" href={href}>
    <h2 class="lead-title">{article.title}</h2>
    {description && <p class="lead-dek">{description}</p>}
  </a>
  <MetadataLine
    type={article.type}
    date={article.date}
    readingTime={article.readingTime}
  />
  {topics.length > 0 && (
    <div class="lead-topics">
      {topics.map((topic) => (
        <TopicPill topic={topic} />
      ))}
    </div>
  )}
</article>

<style>
  .lead-story {
    padding: 0 0 1.5rem;
  }

  .lead-label {
    margin: 0 0 0.6rem;
    color: var(--accent);
  }

  .lead-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .lead-link:hover .lead-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .lead-title {
    max-width: 14ch;
  }

  .lead-dek {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0.85rem 0 0;
    max-width: 46ch;
  }

  .lead-story :global(.metadata-line) {
    margin-top: 0.75rem;
  }

  .lead-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    margin-top: 0.85rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }
</style>
