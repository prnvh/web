---
import { formatDate, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;
const href = getArticleHref(article);
const dek = article.subtitle ?? article.description ?? '';
---

<article class:list={['essay-item', { 'essay-item--featured': featured }]}>
  <a class="essay-item-link" href={href}>
    <h3 class="essay-item-title">{article.title}</h3>
    {dek && <p class="essay-item-dek">{dek}</p>}
    <p class="label essay-item-meta">{formatDate(article.date)}</p>
  </a>
</article>

<style>
  .essay-item {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }

  .essay-item--featured {
    padding: 0 0 2rem;
    border-top: none;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }

  .essay-item-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .essay-item-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
    font-weight: 700;
    margin: 0;
    max-width: 20ch;
  }

  .essay-item--featured .essay-item-title {
    font-size: clamp(2rem, 3.5vw, 3.25rem);
    max-width: 18ch;
  }

  .essay-item-dek {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0.85rem 0 0.65rem;
    max-width: 50ch;
  }

  .essay-item-meta {
    margin: 0;
    color: var(--faint);
  }

  .essay-item-link:hover .essay-item-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
