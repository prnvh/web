---
export interface Source {
  title: string;
  url: string;
  note?: string;
}

interface Props {
  sources: Source[];
  heading?: string;
}

const { sources, heading = 'Sources' } = Astro.props;
---

{sources.length > 0 && (
  <section class="source-list" aria-labelledby="source-list-heading">
    <h2 class="source-heading" id="source-list-heading">{heading}</h2>
    <ol class="sources">
      {sources.map((source) => (
        <li>
          <a href={source.url}>{source.title}</a>
          {source.note && <span class="source-note"> — {source.note}</span>}
        </li>
      ))}
    </ol>
  </section>
)}

<style>
  .source-list {
    margin: 2.5rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .source-heading {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.85rem;
    font-weight: 600;
  }

  .sources {
    margin: 0;
    padding-left: 1.25rem;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.55;
  }

  .sources li + li {
    margin-top: 0.4rem;
  }

  .sources a {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .sources a:hover {
    color: var(--accent);
  }

  .source-note {
    color: var(--muted);
  }
</style>
