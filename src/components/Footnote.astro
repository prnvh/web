---
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<span class="footnote-ref" id={`fnref-${id}`}>
  <a href={`#fn-${id}`}>[{id}]</a>
</span>

<style>
  .footnote-ref a {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
