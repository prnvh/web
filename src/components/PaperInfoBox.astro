---
export interface PaperInfo {
  title: string;
  authors?: string;
  institution?: string;
  year?: string | number;
  link?: string;
  status?: 'paper' | 'benchmark' | 'blog' | 'technical report' | string;
}

interface Props extends PaperInfo {}

const { title, authors, institution, year, link, status } = Astro.props;
const statusLabel = status
  ? status.charAt(0).toUpperCase() + status.slice(1)
  : null;
---

<aside class="paper-box" aria-labelledby="paper-box-heading">
  <p class="paper-label" id="paper-box-heading">Paper / Result</p>
  <dl class="paper-details">
    <div class="paper-row">
      <dt>Title</dt>
      <dd>
        {link ? (
          <a href={link}>{title}</a>
        ) : (
          title
        )}
      </dd>
    </div>
    {authors && (
      <div class="paper-row">
        <dt>Authors</dt>
        <dd>{authors}</dd>
      </div>
    )}
    {institution && (
      <div class="paper-row">
        <dt>Institution</dt>
        <dd>{institution}</dd>
      </div>
    )}
    {year !== undefined && (
      <div class="paper-row">
        <dt>Year</dt>
        <dd>{year}</dd>
      </div>
    )}
    {link && (
      <div class="paper-row">
        <dt>Link</dt>
        <dd>
          <a href={link}>{link}</a>
        </dd>
      </div>
    )}
    {statusLabel && (
      <div class="paper-row">
        <dt>Status</dt>
        <dd>{statusLabel}</dd>
      </div>
    )}
  </dl>
</aside>

<style>
  .paper-box {
    border: 1px solid var(--border);
    background: var(--paper);
    padding: 1rem 1.15rem;
    margin: 1.5rem 0;
  }

  .paper-label {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .paper-details {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.5;
  }

  .paper-row {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: 0.5rem 1rem;
    padding: 0.35rem 0;
    border-top: 1px solid var(--border);
  }

  .paper-row:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .paper-row dt {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--faint);
    margin: 0;
  }

  .paper-row dd {
    margin: 0;
    color: var(--text);
  }

  .paper-row a {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
    word-break: break-word;
  }

  .paper-row a:hover {
    color: var(--accent);
  }
</style>
