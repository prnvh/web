---
import { site } from '../config/site';

interface Props {
  placeholder?: string;
}

const { placeholder = 'Search articles…' } = Astro.props;
const searchPath = site.searchPath ?? '/search';
---

<form class="search-box" action={searchPath} method="get" role="search">
  <label class="visually-hidden" for="site-search">Search</label>
  <input
    id="site-search"
    type="search"
    name="q"
    placeholder={placeholder}
    autocomplete="off"
  />
  <button type="submit">Search</button>
</form>

<style>
  .search-box {
    display: flex;
    gap: 0.35rem;
    align-items: stretch;
  }

  .search-box input {
    flex: 1;
    min-width: 0;
    font-family: var(--font-sans);
    font-size: 13px;
    padding: 0.4rem 0.55rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    border-radius: 0;
  }

  .search-box input:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .search-box button {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    cursor: pointer;
    border-radius: 0;
  }

  .search-box button:hover {
    border-color: var(--rule);
    color: var(--accent);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
