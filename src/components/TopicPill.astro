---
import { slugifyTopic } from '../utils/articles';

interface Props {
  topic: string;
  href?: string;
}

const { topic, href } = Astro.props;
const link = href ?? `/topics/${slugifyTopic(topic)}`;
---

<a class="topic-pill label" href={link}>{topic}</a>

<style>
  .topic-pill {
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: var(--text-meta-size);
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .topic-pill:hover {
    color: var(--accent);
  }
</style>
