---
import { render } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import PaperMetaTable from './PaperMetaTable.astro';
import { normalizeSummary } from '../lib/summary';
import {
  getArticlePath,
  getArticleSlug,
  getByType,
  getRelated,
  toListItem,
  type ArticleEntry,
} from '../utils/articles';

interface Props {
  entry: ArticleEntry;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const data = entry.data;
const slug = getArticleSlug(entry);
const summary = normalizeSummary(data.summary);
const relatedEntries = await getRelated(entry);
const related = relatedEntries.map(toListItem);
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));
const canonical = new URL(getArticlePath(entry), Astro.site).toString();

const allBriefs = (await getByType('brief')).map(toListItem);
const railBriefs = allBriefs.filter((b) => b.slug !== slug).slice(0, 3);

const allNotes = (await getByType('research-note')).map(toListItem);
const railNotes = allNotes.filter((n) => n.slug !== slug).slice(0, 3);

const furtherReading =
  data.sources?.map((s) => {
    if (typeof s === 'string') {
      return { label: 'Source', title: s, href: '#' };
    }
    const label =
      s.note ??
      (s.url?.includes('arxiv') ? 'Paper' : s.url?.includes('youtube') ? 'Video' : 'Blog');
    return { label, title: s.title, href: s.url ?? '#' };
  }) ?? [];

const paperAuthors = data.paperInfo?.authors
  ? Array.isArray(data.paperInfo.authors)
    ? data.paperInfo.authors.join(', ')
    : data.paperInfo.authors
  : undefined;

const pullQuote = data.pullQuote
  ? {
      text: data.pullQuote.text,
      attribution: data.pullQuote.attribution,
    }
  : data.type === 'essay'
    ? {
        text: 'Progress is no longer about how much we can scale, but how precisely we can steer.',
        attribution: '— Frontier Manual',
      }
    : undefined;
---

<ArticleLayout
  title={data.title}
  subtitle={data.subtitle}
  description={data.description}
  type={data.type}
  date={data.date}
  author={data.author}
  readingTime={data.readingTime}
  topics={data.topics}
  summary={summary}
  toc={toc}
  related={related}
  canonical={canonical}
  heroImage={data.heroImage}
  pullQuote={pullQuote}
  railBriefs={railBriefs}
  railNotes={railNotes}
  furtherReading={furtherReading}
>
  {data.paperInfo && data.type === 'research-note' && (
    <PaperMetaTable
      slot="paper-meta"
      paper={data.paperInfo.paperTitle}
      year={data.paperInfo.year}
      authors={paperAuthors}
      source="Paper"
      sourceUrl={data.paperInfo.link}
    />
  )}
  {data.orientation && (
    <div slot="orientation" class="orientation-box">
      <p class="orientation-box__label">Orientation</p>
      <p><strong>Covers:</strong> {data.orientation.covers}</p>
      <p><strong>For:</strong> {data.orientation.audience}</p>
      <p>
        <strong>Read first:</strong>{' '}
        {Array.isArray(data.orientation.readFirst)
          ? data.orientation.readFirst.join(' · ')
          : data.orientation.readFirst}
      </p>
    </div>
  )}
  <Content />
</ArticleLayout>
