---
import { formatArticleType, type ArticleType } from '../utils/articles';

interface Props {
  type: ArticleType;
}

const { type } = Astro.props;
const label = formatArticleType(type);
---

<span class="label type-label">{label}</span>

<style>
  .type-label {
    color: var(--muted);
  }
</style>
