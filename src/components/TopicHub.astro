---
import { slugifyTopic } from '../utils/articles';

interface Props {
  name: string;
  description?: string;
  href?: string;
}

const { name, description, href } = Astro.props;
const link = href ?? `/topics/${slugifyTopic(name)}`;
---

<article class="topic-hub">
  <a class="topic-hub-link" href={link}>
    <h3 class="topic-hub-name">{name}</h3>
    {description && <p class="topic-hub-desc">{description}</p>}
  </a>
</article>

<style>
  .topic-hub {
    border-top: 1px solid var(--border);
    padding: 0.75rem 0;
  }

  .topic-hub-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .topic-hub-link:hover .topic-hub-name {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .topic-hub-name {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0;
    color: var(--text);
  }

  .topic-hub-desc {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.45;
    color: var(--muted);
    margin: 0.25rem 0 0;
    display: none;
  }

  @media (min-width: 768px) {
    .topic-hub-desc {
      display: block;
    }
  }
</style>
