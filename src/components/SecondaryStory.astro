---
import MetadataLine from './MetadataLine.astro';
import { getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  dek?: string;
  label?: string;
}

const { article, dek, label = 'Also' } = Astro.props;
const href = getArticleHref(article);
const description = dek ?? article.subtitle ?? article.description ?? '';
---

<article class="secondary-story">
  <p class="label secondary-label">{label}</p>
  <a class="secondary-link" href={href}>
    <h3 class="story-title">{article.title}</h3>
    {description && <p class="secondary-dek">{description}</p>}
  </a>
  <MetadataLine
    type={article.type}
    date={article.date}
    readingTime={article.readingTime}
  />
</article>

<style>
  .secondary-story {
    padding: 1rem 0 0;
    border-top: 1px solid var(--border);
  }

  .secondary-story:first-child {
    border-top: none;
    padding-top: 0;
  }

  .secondary-label {
    margin: 0 0 0.4rem;
  }

  .secondary-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .secondary-link:hover .story-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .story-title {
    max-width: 22ch;
  }

  .secondary-dek {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--muted);
    margin: 0.45rem 0 0.5rem;
    max-width: 38ch;
  }

  .secondary-story :global(.metadata-line) {
    margin-top: 0.4rem;
  }
</style>
