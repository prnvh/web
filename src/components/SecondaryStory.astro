---
import { formatDate, formatArticleType, getArticleHref, getReadingTimeLabel, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  dek?: string;
}

const { article, dek } = Astro.props;
const href = getArticleHref(article);
const description = dek ?? article.subtitle ?? article.description ?? '';
const typeLabel = formatArticleType(article.type).toUpperCase();
const timeLabel = getReadingTimeLabel(article.readingTime);
---

<article class="secondary-story">
  <p class="label secondary-type">{typeLabel}</p>
  <a class="secondary-link" href={href}>
    <h3 class="story-title">{article.title}</h3>
    {description && <p class="secondary-dek">{description}</p>}
  </a>
  <p class="secondary-meta">
    <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
    {timeLabel && <span> · {timeLabel}</span>}
  </p>
</article>

<style>
  .secondary-story {
    padding: 0.85rem 0 0;
    border-top: 1px solid var(--border);
  }

  .secondary-story:first-child {
    border-top: none;
    padding-top: 0;
  }

  .secondary-type {
    margin: 0 0 0.35rem;
    color: var(--faint);
  }

  .secondary-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .secondary-link:hover .story-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .secondary-dek {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--muted);
    margin: 0.35rem 0 0;
    max-width: 36ch;
  }

  .secondary-meta {
    font-family: var(--font-ui);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--faint);
    margin: 0.4rem 0 0;
  }
</style>
