---
import { formatDate, getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
  showMetadata?: boolean;
}

const { article, showMetadata = true } = Astro.props;
const href = getArticleHref(article);
const dek = article.subtitle ?? article.description ?? '';
const readingLabel =
  article.readingTime !== undefined
    ? typeof article.readingTime === 'number'
      ? `${article.readingTime} min`
      : article.readingTime
    : null;
---

<article class="research-item">
  <a class="research-item-link" href={href}>
    {showMetadata && (
      <p class="label research-item-meta">
        Research Note · {formatDate(article.date)}
        {readingLabel && ` · ${readingLabel}`}
      </p>
    )}
    <h3 class="research-item-title">{article.title}</h3>
    {dek && <p class="research-item-dek">{dek}</p>}
  </a>
</article>

<style>
  .research-item {
    padding: 0.85rem 0;
    border-top: 1px solid var(--border);
  }

  .research-item-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .research-item-meta {
    margin: 0 0 0.35rem;
    color: var(--faint);
  }

  .research-item-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
    max-width: 36ch;
  }

  .research-item-dek {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0.35rem 0 0;
    max-width: 48ch;
  }

  .research-item-link:hover .research-item-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
