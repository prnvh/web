---
import {
  formatDate,
  formatArticleType,
  getArticleHref,
  getReadingTimeLabel,
  type ArticleListItem,
} from '../utils/articles';

interface Props {
  heading: string;
  articles: ArticleListItem[];
  moreHref?: string;
  moreLabel?: string;
}

const { heading, articles, moreHref, moreLabel } = Astro.props;
---

{articles.length > 0 && (
  <section class="rail-block">
    <h2 class="rail-block__heading">{heading}</h2>
    {articles.map((article) => {
      const dek = article.subtitle ?? article.description ?? '';
      const time = getReadingTimeLabel(article.readingTime);
      return (
        <article class="rail-item">
          <a href={getArticleHref(article)}>
            <p class="rail-item__meta">
              <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
              {article.type && (
                <>
                  {' '}
                  · {formatArticleType(article.type)}
                </>
              )}
            </p>
            <span class="rail-item__title">{article.title}</span>
            {dek && <span class="rail-item__dek">{dek}</span>}
            {time && !dek && <span class="rail-item__dek">{time}</span>}
          </a>
        </article>
      );
    })}
    {moreHref && moreLabel && (
      <a class="rail-more" href={moreHref}>
        {moreLabel}
      </a>
    )}
  </section>
)}
