---
import { site } from '../config/site';
import { formatDate } from '../utils/articles';
import Masthead from './Masthead.astro';
import Nav from './Nav.astro';

const today = formatDate(new Date());
const subscribeHref = site.subscribePath;
---

<header class="site-header">
  <div class="site-container">
    <input
      type="checkbox"
      id="nav-open"
      class="nav-check"
      aria-hidden="true"
      tabindex="-1"
    />
    <div class="header-strip">
      <time class="label header-date" datetime={new Date().toISOString().slice(0, 10)}>
        {today}
      </time>
      <label class="label header-menu" for="nav-open">Menu</label>
      <p class="header-tagline">{site.tagline}</p>
      <a class="header-subscribe label" href={subscribeHref}>Subscribe</a>
    </div>
    <Masthead />
    <Nav />
  </div>
</header>

<style>
  .site-header {
    background: var(--bg);
    border-bottom: 2px solid var(--rule);
  }

  .nav-check {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .header-strip {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
  }

  .header-date {
    justify-self: start;
  }

  .header-menu {
    display: none;
    justify-self: start;
    cursor: pointer;
    color: var(--text);
  }

  .header-tagline {
    font-family: var(--font-ui);
    font-size: var(--text-label-size);
    letter-spacing: var(--text-label-tracking);
    text-transform: uppercase;
    color: var(--faint);
    text-align: center;
    margin: 0;
    justify-self: center;
  }

  .header-subscribe {
    justify-self: end;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .header-subscribe:hover {
    color: var(--text);
  }

  @media (min-width: 900px) {
    .header-menu {
      display: none !important;
    }

    .header-date,
    .header-tagline {
      display: block;
    }
  }

  @media (max-width: 899px) {
    .header-strip {
      grid-template-columns: auto 1fr auto;
    }

    .header-date,
    .header-tagline {
      display: none;
    }

    .header-menu {
      display: block;
    }
  }
</style>
