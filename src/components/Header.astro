---
import { site } from '../config/site';
import { formatDate } from '../utils/articles';
import Masthead from './Masthead.astro';
import Nav from './Nav.astro';

const today = formatDate(new Date());
const subscribeHref = site.subscribePath;
---

<header class="site-header">
  <div class="site-container">
    <div class="header-strip">
      <time class="label header-date" datetime={new Date().toISOString().slice(0, 10)}>{today}</time>
      <label class="label header-menu" for="nav-open">Menu</label>
      <span class="header-tagline">{site.tagline}</span>
      <a class="header-subscribe label" href={subscribeHref}>Subscribe</a>
    </div>
    <Masthead />
    <Nav />
  </div>
</header>

<style>
  .site-header {
    background: var(--bg);
    border-bottom: 2px solid var(--rule);
  }

  .header-strip {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
  }

  .header-date {
    justify-self: start;
  }

  .header-menu {
    display: none;
    justify-self: start;
    cursor: pointer;
    color: var(--text);
  }

  .header-tagline {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--faint);
    text-align: center;
    margin: 0;
    display: none;
  }

  .header-subscribe {
    justify-self: end;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .header-subscribe:hover {
    color: var(--text);
  }

  @media (min-width: 720px) {
    .header-tagline {
      display: block;
    }
  }

  @media (max-width: 899px) {
    .header-strip {
      grid-template-columns: auto 1fr auto;
    }

    .header-date {
      display: none;
    }

    .header-menu {
      display: block;
    }

    .header-tagline {
      display: none;
    }
  }
</style>
