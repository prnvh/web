---
import { site, navItems } from '../config/site';
import { formatDate } from '../utils/articles';
import Masthead from './Masthead.astro';
import Nav from './Nav.astro';

interface Props {
  mode?: 'masthead' | 'compact';
}

const { mode = 'masthead' } = Astro.props;
const today = formatDate(new Date());
const subscribeHref = site.subscribePath;
const isCompact = mode === 'compact';
---

<header class:list={['site-header', isCompact && 'site-header--compact']}>
  <div class="site-container">
    <input
      type="checkbox"
      id="nav-open"
      class="nav-check"
      aria-hidden="true"
      tabindex="-1"
    />
    {!isCompact && (
      <>
        <div class="header-strip">
          <time class="header-date" datetime={new Date().toISOString().slice(0, 10)}>
            {today}
          </time>
          <label class="header-menu" for="nav-open">Menu</label>
          <p class="header-tagline">{site.tagline}</p>
          <a class="header-subscribe" href={subscribeHref}>Subscribe</a>
        </div>
        <Masthead />
      </>
    )}
    <Nav showBrand={isCompact} />
  </div>
</header>

<style>
  .site-header {
    background: var(--bg);
  }

  .nav-check {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .header-menu {
    display: none;
    justify-self: start;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
  }

  @media (max-width: 899px) {
    .header-strip {
      grid-template-columns: auto 1fr auto !important;
    }

    .header-date,
    .header-tagline {
      display: none;
    }

    .header-menu {
      display: block;
    }
  }
</style>
