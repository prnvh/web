---
import { getArticleHref, type ArticleListItem } from '../utils/articles';

interface Props {
  article: ArticleListItem;
}

const { article } = Astro.props;
const href = getArticleHref(article);
const dek = article.subtitle ?? article.description ?? '';
---

<article class="col-story">
  <a href={href}>
    <h3 class="col-story-title">{article.title}</h3>
    {dek && <p class="col-story-dek">{dek}</p>}
  </a>
</article>

<style>
  .col-story {
    padding: 0.75rem 0;
    border-top: 1px solid var(--border);
  }

  .col-story:first-child {
    border-top: none;
    padding-top: 0;
  }

  .col-story a {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .col-story-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
  }

  .col-story-dek {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.45;
    color: var(--muted);
    margin: 0.3rem 0 0;
  }

  .col-story a:hover .col-story-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
