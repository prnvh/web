---
import {
  formatDate,
  formatArticleType,
  getArticleHref,
  getReadingTimeLabel,
  type ArticleListItem,
} from '../utils/articles';

interface Props {
  articles: ArticleListItem[];
  heading?: string;
}

const { articles, heading = 'Read next' } = Astro.props;
const items = articles.slice(0, 3);
---

{items.length > 0 && (
  <section class="fm-read-next" aria-labelledby="read-next-heading">
    <h2 id="read-next-heading">{heading}</h2>
    <div class="fm-read-next-grid">
      {items.map((article) => {
        const dek = article.subtitle ?? article.description ?? '';
        const time = getReadingTimeLabel(article.readingTime);
        return (
          <article class="fm-read-next-card">
            <p class="fm-read-next-kicker">{formatArticleType(article.type)}</p>
            <h3 class="fm-read-next-title">
              <a href={getArticleHref(article)}>{article.title}</a>
            </h3>
            {dek && <p class="fm-read-next-dek">{dek}</p>}
            <p class="fm-read-next-meta">
              <time datetime={article.date.toISOString()}>{formatDate(article.date)}</time>
              {time && <> · {time}</>}
            </p>
            <a class="fm-read-next-arrow" href={getArticleHref(article)} aria-hidden="true">
              →
            </a>
          </article>
        );
      })}
    </div>
  </section>
)}
