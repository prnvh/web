---
import { articlePath, formatDate, typeLabelUpper, type Article } from '@/lib/articles';

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
---

{articles.length > 0 && (
  <section class="read-next">
    <div class="site-container">
      <h2>Read next</h2>
      <div class="read-next__grid">
        {articles.slice(0, 3).map((item) => (
          <article class="read-next__item">
            <p class="read-next__type">{typeLabelUpper(item.data.type)}</p>
            <h3 class="read-next__title">
              <a href={articlePath(item)}>{item.data.title}</a>
            </h3>
            <p class="read-next__sum">{item.data.description}</p>
            <p class="read-next__meta">
              {formatDate(item.data.date)} · {item.data.readingTime}
              <a href={articlePath(item)} aria-label={`Read ${item.data.title}`}>→</a>
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
