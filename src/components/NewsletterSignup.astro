---
import { site } from '../config/site';

interface Props {
  compact?: boolean;
  action?: string;
}

const { compact = false, action = '#' } = Astro.props;
---

<aside
  class:list={['newsletter', { 'newsletter--compact': compact }]}
  aria-labelledby="newsletter-heading"
>
  <h2 class="newsletter-heading" id="newsletter-heading">Get the weekly note.</h2>
  <p class="newsletter-text">
    Essays, briefs, and field maps — one email every week or two.
  </p>

  <form class="newsletter-form" action={action} method="post">
    <label class="visually-hidden" for="newsletter-email">Email address</label>
    <input
      id="newsletter-email"
      name="email"
      type="email"
      required
      autocomplete="email"
      placeholder="you@example.com"
    />
    <button class="button" type="submit">Subscribe</button>
  </form>

  <p class="newsletter-privacy label">
    <a href={site.subscribePath}>Privacy</a>
  </p>
</aside>

<style>
  .newsletter {
    padding: 0;
    border: none;
    background: transparent;
  }

  .newsletter-heading {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 0.35rem;
  }

  .newsletter-text {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0 0 0.85rem;
    max-width: 36ch;
  }

  .newsletter-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .newsletter-form input {
    flex: 1 1 11rem;
    min-width: 0;
    font-family: var(--font-ui);
    font-size: 14px;
    padding: 10px 10px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    border-radius: 0;
  }

  .newsletter-privacy {
    margin: 0.5rem 0 0;
    color: var(--faint);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
