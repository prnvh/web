---
import { site } from '../config/site';

interface Props {
  compact?: boolean;
  action?: string;
}

const { compact = false, action = '#' } = Astro.props;
---

<aside
  class:list={['newsletter', { 'newsletter--compact': compact }]}
  aria-labelledby="newsletter-heading"
>
  <h2 class="newsletter-heading" id="newsletter-heading">Get the frontier briefing</h2>
  <p class="newsletter-text">
    One clear briefing on frontier AI, research, and technology every week or two.
  </p>

  <slot name="embed">
    <form class="newsletter-form" action={action} method="post">
      <label class="visually-hidden" for="newsletter-email">Email address</label>
      <input
        id="newsletter-email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
      />
      <button class="button" type="submit">Subscribe</button>
    </form>
  </slot>

  <p class="newsletter-privacy label">
    Unsubscribe anytime. <a href={site.subscribePath}>Privacy note</a>.
  </p>
</aside>

<style>
  .newsletter {
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--paper);
  }

  .newsletter--compact {
    padding: 0;
    border: none;
    background: transparent;
  }

  .newsletter--compact .newsletter-heading {
    font-size: 1.05rem;
  }

  .newsletter-heading {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 0.4rem;
    color: var(--text);
  }

  .newsletter-text {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0 0 0.75rem;
    max-width: 42ch;
  }

  .newsletter-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: stretch;
  }

  .newsletter-form input {
    flex: 1 1 12rem;
    min-width: 0;
    font-family: var(--font-ui);
    font-size: 14px;
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    border-radius: 0;
  }

  .newsletter-privacy {
    margin: 0.55rem 0 0;
    color: var(--faint);
  }

  .newsletter-privacy a {
    color: var(--muted);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
